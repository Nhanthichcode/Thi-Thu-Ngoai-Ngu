@model ForgotPasswordVM
@{
    ViewData["Title"] = "Quên mật khẩu";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
         style="top: 60px; z-index: 1050;" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
         style="top: 60px; z-index: 1050;" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 text-center">
            <div class="mb-4">
                <i class="bi bi-patch-question text-primary" style="font-size: 4rem;"></i>
            </div>
            <h2 class="fw-bold mb-3">Bạn quên mật khẩu?</h2>
            <p class="text-muted mb-4">Nhập thông tin tài khoản để nhận liên kết đặt lại mật khẩu.</p>

            <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">             
                <!-- Hiển thị lỗi tổng quát -->
                <div asp-validation-summary="ModelOnly" class="text-danger small text-start mb-2"></div>

                <form id="forgotPasswordForm" asp-action="ForgotPassword" method="post">
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold small">Nhập Email của bạn</label>
                        <input asp-for="Identifier" class="form-control rounded-pill px-3 shadow-none" placeholder="example@gmail.com" />
                        <span asp-validation-for="Identifier" class="text-danger small"></span>
                    </div>

                    <button  class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-orange">
                        <span id="btnText">Xác minh qua Email</span>
                        <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                    </button>
                    
                    @* Bạn có thể thêm nút SMS ở đây nếu muốn *@
                </form>
            </div>

            <a asp-action="Login" class="text-decoration-none fw-bold text-muted small">
                <i class="bi bi-arrow-left"></i> Quay lại Đăng nhập
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" /> @* Thêm dòng này để kiểm tra dữ liệu ngay tại máy khách *@
    <script>
        document.getElementById('forgotPasswordForm').onsubmit = function () {
            // Chỉ hiện spinner nếu form hợp lệ (đã nhập liệu)
            if ($(this).valid()) {
                var btn = document.getElementById('btnSendEmail');
                var btnText = document.getElementById('btnText');
                var spinner = document.getElementById('btnSpinner');

                btn.disabled = true;
                btnText.innerText = "Đang gửi...";
                spinner.classList.remove('d-none');
            }
        };
    </script>
}