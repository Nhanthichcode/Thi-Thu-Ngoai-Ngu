@{   
    ViewData["Title"] = "Tài khoản bị khóa";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="text-center animate__animated animate__fadeIn" style="max-width: 500px;">
        <!-- Icon cảnh báo -->
        <div class="mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 rounded-circle" style="width: 120px; height: 120px;">
                <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem;"></i>
            </div>
        </div>

        <!-- Tiêu đề -->
        <h2 class="fw-bold mb-3 text-dark">Truy cập bị từ chối</h2>
        
        <!-- Nội dung -->
        <p class="text-muted mb-5 fs-5">
            Rất tiếc, tài khoản của bạn hiện đang bị tạm khóa bởi Quản trị viên hệ thống. 
            Vui lòng liên hệ bộ phận hỗ trợ nếu bạn cho rằng đây là một sự nhầm lẫn.
        </p>

        <!-- Nút hành động -->
        <div class="d-grid gap-2">            
            <a asp-area="" asp-controller="Account" asp-action="Contact" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-orange">
                Liên hệ hỗ trợ
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-light-soft btn-lg rounded-pill fw-bold text-secondary">
                Quay về trang chủ
            </a>
        </div>
    </div>
</div>