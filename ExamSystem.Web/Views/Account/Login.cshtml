@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@model ExamSystem.Web.Models.LoginVM
@inject SignInManager<AppUser> SignInManager

@{
    ViewData["Title"] = "Chào mừng trở lại";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
         style="top: 60px; z-index: 1050;" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
         style="top: 60px; z-index: 1050;" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="auth-page-wrapper py-3">
    <div class="auth-card py-4 shadow-lg" style="max-width: 400px;">
        <div class="text-center mb-3">
            <h2 class="auth-title h3">Chào mừng trở lại</h2>
            <p class="auth-subtitle small">Vui lòng nhập thông tin để đăng nhập.</p>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2 text-center"></div>

            <div class="mb-2">
                <label class="fw-bold small mb-1 ms-2">Địa chỉ Email</label>
                <div class="auth-input-container">
                    <input asp-for="Email" class="auth-input py-2" placeholder="name@company.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small ms-2"></span>
            </div>

            <div class="mb-2">
                <label class="fw-bold small mb-1 ms-2">Mật khẩu</label>
                <div class="auth-input-container">
                    <input asp-for="Password" type="password" class="auth-input py-2" placeholder="••••••••" id="Password" />
                    <i class="bi bi-eye-slash" id="togglePass" onclick="togglePassword('Password', 'togglePass')"></i>
                </div>
                <span asp-validation-for="Password" class="text-danger small ms-2"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                <div class="form-check auth-checkbox">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                    <label class="form-check-label text-muted small" for="rememberMe">Ghi nhớ tôi</label>
                </div>
                <a asp-action="ForgotPassword" class="auth-link small">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-auth-primary py-2 mb-3">
                Đăng nhập <i class="bi bi-arrow-right ms-1"></i>
            </button>
        </form>

        <div class="auth-divider mb-3">Hoặc tiếp tục với</div>

        <form asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <button type="submit" name="provider" value="Google" class="btn-auth-google py-2 mb-3 d-flex align-items-center justify-content-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" class="me-2">
                    <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
                    <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
                    <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
                    <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
                </svg>
                Google
            </button>
        </form>

        <div class="text-center">
            <p class="small text-muted mb-0">
                Chưa có tài khoản? <a asp-action="Register" class="auth-link">Đăng ký ngay</a>
            </p>
        </div>
    </div>
</div>