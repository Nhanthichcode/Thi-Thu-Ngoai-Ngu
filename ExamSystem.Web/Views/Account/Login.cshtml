@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@model ExamSystem.Web.Models.LoginVM
@inject SignInManager<AppUser> SignInManager

@{
    ViewData["Title"] = "Đăng nhập";
    var schemes = await SignInManager.GetExternalAuthenticationSchemesAsync();
    var loginProviders = schemes.ToList();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 col-xl-4">
            <div class="card auth-card">
                <div class="auth-header mb-4">
                    <i class="bi bi-person-circle display-4 mb-2"></i>
                    <h3 class="fw-bold mb-0">Đăng Nhập</h3>
                    <p class="mb-0 text-white-50 small">Chào mừng bạn quay trở lại</p>
                </div>

                <div class="card-body p-4 pt-2">
                    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

                        <div class="mb-3 position-relative">
                            <i class="bi bi-envelope-fill input-icon"></i>
                            <input asp-for="Email" class="form-control form-control-lg bg-light" placeholder="Nhập Email của bạn" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3 position-relative">
                            <i class="bi bi-shield-lock-fill input-icon"></i>
                            <input asp-for="Password" class="form-control form-control-lg bg-light" placeholder="Nhập mật khẩu" id="Password" type="password" />
                            <i class="bi bi-eye-slash-fill password-toggle" id="togglePasswordIcon" onclick="togglePass('Password', 'togglePasswordIcon')"></i>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 small">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                                <label class="form-check-label text-muted" for="rememberMe">
                                    @Html.DisplayNameFor(m => m.RememberMe)
                                </label>
                            </div>
                            <a asp-action="ForgotPassword" class="text-decoration-none auth-link fw-bold">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn btn-brand w-100 fw-bold py-3 mb-4 shadow-sm" style="border-radius: 0.5rem;">
                            ĐĂNG NHẬP
                        </button>
                    </form>

                    @if (loginProviders.Any())
                    {
                        <div class="position-relative text-center mb-4">
                            <hr class="text-muted">
                            <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 small text-muted fw-bold">HOẶC</span>
                        </div>

                        <form asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="text-center">
                            @foreach (var provider in loginProviders)
                            {
                                <button type="submit" class="btn btn-outline-success w-100 fw-bold py-2 mb-2 d-flex align-items-center justify-content-center"
                                        name="provider" value="@provider.Name">
                                    <i class="bi bi-google me-2"></i> Đăng nhập với @provider.DisplayName
                                </button>
                            }
                        </form>
                    }

                    <div class="text-center mt-4 pt-3 border-top">
                        <span class="small text-muted">Chưa có tài khoản?</span>
                        <a asp-action="Register" class="fw-bold text-decoration-none ms-1 auth-link">Đăng ký ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePass(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("bi-eye-slash-fill", "bi-eye-fill");
        } else {
            input.type = "password";
            icon.classList.replace("bi-eye-fill", "bi-eye-slash-fill");
        }
    }
</script>