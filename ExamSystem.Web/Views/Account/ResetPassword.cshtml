@using ExamSystem.Web.Models
@model ResetPasswordVM
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
  
}

<div class="auth-container d-flex align-items-center justify-content-center min-vh-100 bg-light">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden" style="max-width: 450px; width: 100%;">
        <div class="py-4 text-center text-white" style="background-color: #f47b25;">
            <h3 class="fw-bold mb-0">Thi Thử Ngoại Thử</h3>
            <p class="small mb-0 opacity-75">Thiết lập lại mật khẩu tài khoản: <strong class="text-white">@Model.Email</strong></p>
        </div>

        <div class="card-body p-4 p-md-5 bg-white">
            <form asp-action="ResetPassword" method="post">
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

                <div class="mb-3">
                    <label asp-for="Password" class="fw-bold small mb-1 ms-2">Mật khẩu mới</label>
                    <div class="auth-input-container position-relative d-flex align-items-center">
                        <input asp-for="Password"
                               type="password"
                               class="auth-input form-control py-2 rounded-pill shadow-none"
                               placeholder="Nhập mật khẩu mới..."
                               id="new-password"
                               style="padding-right: 45px;" />
                        <i class="bi bi-eye-slash auth-icon-right position-absolute"
                           id="toggleIconNew"
                           style="right: 15px; cursor: pointer; color: #6c757d;"
                           onclick="togglePassword('new-password', 'toggleIconNew')"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small ms-2"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="fw-bold small mb-1 ms-2">Xác nhận mật khẩu</label>
                    <div class="auth-input-container position-relative d-flex align-items-center">
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="auth-input form-control py-2 rounded-pill shadow-none"
                               placeholder="Gõ lại mật khẩu mới..."
                               id="confirm-password"
                               style="padding-right: 45px;" />
                        <i class="bi bi-eye-slash auth-icon-right position-absolute"
                           id="toggleIconConfirm"
                           style="right: 15px; cursor: pointer; color: #6c757d;"
                           onclick="togglePassword('confirm-password', 'toggleIconConfirm')"></i>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small ms-2"></span>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn text-white fw-bold py-2 rounded-pill shadow-sm hover-up"
                            style="background-color: #f47b25;">
                        <i class="bi bi-shield-check me-2"></i> XÁC NHẬN THAY ĐỔI
                    </button>
                    <a asp-action="Login" class="btn btn-link text-decoration-none text-muted small mt-2">
                        Quay lại trang Đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
