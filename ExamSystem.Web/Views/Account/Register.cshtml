@model ExamSystem.Web.Models.RegisterVM
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="auth-page-wrapper d-flex align-items-center">
    <div class="container-fluid max-w-1200 mx-auto">
        <div class="row w-100 align-items-center justify-content-center m-0">

            <div class="col-lg-6 d-none d-lg-block">
                <div class="visual-container">
                    
                    <div class="orbit-ring ring-1 zoom-effect-ring"></div>
                    <div class="orbit-ring ring-2 zoom-effect-ring"></div>

                    <div class="central-glowing-box float-slow "><i class="bi bi-person-bounding-box zoom-effect"></i></div>
                    <div class="orbit-icon icon-translate float-med"><i class="bi bi-translate zoom-effect"></i></div>
                    <div class="orbit-icon icon-code float-fast"><i class="bi bi-terminal zoom-effect"></i></div>
                    <div class="orbit-icon icon-user float-med"><i class="bi bi-body-text zoom-effect"></i></div>

                    <div class="position-absolute bottom-0 start-0 pb-5 ps-5">
                        <div style="width: 35px; height: 3px; background-color: #f47b25; margin-bottom: 10px;"></div>
                        <div class="fw-bold text-muted small text-uppercase" style="letter-spacing: 2px; line-height: 1.5;">Ma trận tư duy<br>Ngôn ngữ</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 col-md-8 col-sm-10 z-index-10">
                <div class="auth-card-right">

                    <div class="mb-4 text-center">
                        <h2 class="fw-bold h3 mb-2">Đăng ký tài khoản</h2>
                        <p class="text-muted small">Tham gia và chinh phục ngoại ngữ ngay hôm nay.</p>
                    </div>

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

                        <div class="mb-3">
                            <label class="fw-bold small mb-2">Họ và tên</label>
                            <input asp-for="FullName" class="form-control auth-input py-2 px-3" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold small mb-2">Địa chỉ Email</label>
                            <input asp-for="Email" class="form-control auth-input py-2 px-3" placeholder="name@company.com" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-md-6">
                                <label class="fw-bold small mb-2">Mật khẩu</label>
                                <div class="position-relative">
                                    <input asp-for="Password" type="password" class="form-control auth-input py-2 px-3" placeholder="••••••••" id='RegisPassword' />
                                    <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 text-muted cursor-pointer" id="togglePass1" onclick="togglePassword('RegisPassword', 'togglePass1')"></i>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold small mb-2">Xác nhận</label>
                                <div class="position-relative">
                                    <input asp-for="ConfirmPassword" type="password" class="form-control auth-input py-2 px-3" placeholder="••••••••" id='reRegisPassword' />
                                    <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 text-muted cursor-pointer" id="togglePass2" onclick="togglePassword('reRegisPassword', 'togglePass2')"></i>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-auth-primary py-2 mb-4">
                            Đăng ký ngay <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <div class="d-flex align-items-center mb-4">
                        <hr class="flex-grow-1 text-muted" />
                        <span class="mx-3 text-muted small text-uppercase" style="font-size: 0.7rem;">Hoặc tiếp tục với</span>
                        <hr class="flex-grow-1 text-muted" />
                    </div>

                    <form asp-action="ExternalLogin" method="post">
                        <button type="submit" name="provider" value="Google" class="btn text-dark w-100 py-2 border rounded-pill d-flex align-items-center justify-content-center fw-medium bg-white shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" class="me-2">
                                <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z" />
                                <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z" />
                                <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z" />
                                <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z" />
                            </svg>
                            Google
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="small text-muted mb-0">
                            Đã có tài khoản? <a asp-action="Login" class="text-decoration-none fw-bold" style="color: #f47b25; border-bottom: 1px dashed #f47b25;">Đăng nhập tại đây</a>
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>