@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@model ExamSystem.Web.Models.RegisterVM
@{
    ViewData["Title"] = "Đăng ký";
    var schemes = await SignInManager.GetExternalAuthenticationSchemesAsync();
    var loginProviders = schemes.ToList();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6 col-xl-5">
            <div class="card auth-card">
                <div class="auth-header mb-4">
                    <h3 class="fw-bold mb-1">Tạo Tài Khoản Mới</h3>
                    <p class="mb-0 text-white-50 small">Tham gia hệ thống thi trực tuyến ngay hôm nay!</p>
                </div>

                <div class="card-body p-4 pt-0">
                    <form asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

                        <div class="mb-3 position-relative">
                            <i class="bi bi-person-vcard-fill input-icon"></i>
                            <input asp-for="FullName" class="form-control form-control-lg bg-light" placeholder="Họ và tên của bạn" />
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3 position-relative">
                            <i class="bi bi-envelope-fill input-icon"></i>
                            <input asp-for="Email" class="form-control form-control-lg bg-light" placeholder="Địa chỉ Email" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 mb-3 position-relative">
                                <i class="bi bi-shield-lock-fill input-icon"></i>
                                <input asp-for="Password" class="form-control form-control-lg bg-light" placeholder="Mật khẩu" id="Password" type="password" />
                                <i class="bi bi-eye-slash-fill password-toggle" id="togglePass1" onclick="togglePass('Password', 'togglePass1')"></i>
                                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-sm-6 mb-4 position-relative">
                                <i class="bi bi-shield-check input-icon"></i>
                                <input asp-for="ConfirmPassword" class="form-control form-control-lg bg-light" placeholder="Nhập lại mật khẩu" id="ConfirmPassword" type="password" />
                                <i class="bi bi-eye-slash-fill password-toggle" id="togglePass2" onclick="togglePass('ConfirmPassword', 'togglePass2')"></i>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-brand w-100 fw-bold py-3 mb-3 shadow-sm" style="border-radius: 0.5rem;">
                            ĐĂNG KÝ NGAY
                        </button>
                    </form>

                    @if (loginProviders.Any())
                    {
                        <div class="position-relative text-center mb-3 mt-2">
                            <hr class="text-muted">
                            <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 small text-muted fw-bold">HOẶC</span>
                        </div>

                        <form asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="text-center">
                            @foreach (var provider in loginProviders)
                            {
                                <button type="submit" class="btn btn-outline-success w-100 fw-bold py-2 mb-2 d-flex align-items-center justify-content-center"
                                        name="provider" value="@provider.Name">
                                    <i class="bi bi-google me-2"></i> Đăng ký bằng @provider.DisplayName
                                </button>
                            }
                        </form>
                    }
                    <div class="text-center mt-4">
                        <small class="text-muted">Đã có tài khoản?</small>
                        <a asp-action="Login" class="fw-bold text-decoration-none ms-1 auth-link">Đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePass(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);

        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("bi-eye-slash-fill", "bi-eye-fill");
        } else {
            input.type = "password";
            icon.classList.replace("bi-eye-fill", "bi-eye-slash-fill");
        }
    }
</script>