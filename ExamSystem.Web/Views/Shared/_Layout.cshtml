@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thi Thử Ngoại Ngữ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg sticky-top py-2">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Thi Thử <span class="brand-highlight">Ngoại Ngữ</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            // --- MENU CHO ADMIN & GIÁO VIÊN ---
                            @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-speedometer2 me-1"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                        <i class="bi bi-folder2-open me-1"></i> Quản lý
                                    </a>
                                    <ul class="dropdown-menu shadow-sm border-0">
                                        <li><h6 class="dropdown-header text-uppercase small text-muted">Ngân hàng đề</h6></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Questions" asp-action="Index">Câu hỏi</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Exams" asp-action="Index">Đề thi</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><h6 class="dropdown-header text-uppercase small text-muted">Tài nguyên</h6></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="ReadingPassages" asp-action="Index">Bài đọc</a></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="ListeningResources" asp-action="Index">File nghe</a></li>
                                    </ul>
                                </li>
                            }

                            // --- MENU CHO HỌC VIÊN ---
                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Student" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-pencil-square me-1"></i> Vào thi
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Student" asp-controller="StudentExamsResults" asp-action="Index">
                                        <i class="bi bi-clock-history me-1"></i> Lịch sử
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">
                         <li class="nav-item d-flex align-items-center me-3">
                            <button class="btn btn-sm btn-outline-secondary border rounded-circle shadow-sm d-flex align-items-center justify-content-center"
                                    id="theme-toggle" style="width: 35px; height: 35px;" title="Chuyển đổi giao diện">
                                <i class="bi bi-sun-fill text-warning"></i>
                            </button>
                        </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var user = await UserManager.GetUserAsync(User);
                            var fullName = user?.FullName ?? User.Identity?.Name;
                            var avatarUrl = user?.AvatarUrl;

                                                       <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center text-body" href="#" data-bs-toggle="dropdown">
                                    <div class="rounded-circle d-flex justify-content-center align-items-center me-2 user-avatar border shadow-sm">
                                        @if (!string.IsNullOrEmpty(avatarUrl))
                                        {
                                            <img src="@avatarUrl" class="rounded-circle w-100 h-100" style="object-fit: cover;" />
                                        }
                                        else
                                        {
                                            @(fullName?.Substring(0, 1).ToUpper() ?? "U")
                                        }
                                    </div>
                                    <span class="fw-bold">@fullName</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form id="logoutForm" asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger fw-bold">
                                                <i class="bi bi-power me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <a class="btn btn-outline-secondary btn-sm px-4 rounded-pill" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            <a class="btn btn-primary btn-sm px-4 rounded-pill shadow-sm" asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1 pb-3">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top footer mt-auto border-secondary border-opacity-10">
        <div class="container text-center py-3">
            <h5 class="fw-bold text-uppercase mb-1" style="color: var(--bs-body-color);">Thi Thử Ngoại Ngữ</h5>
            <p class="small text-muted mb-2">Nâng tầm ngoại ngữ - Vươn tới tương lai</p>
            <span class="text-muted small">&copy; @DateTime.Now.Year Thi Thử Ngoại Ngữ. All rights reserved.</span>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>