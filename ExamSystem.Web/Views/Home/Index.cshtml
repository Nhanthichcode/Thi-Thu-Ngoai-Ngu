@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@{
    ViewData["Title"] = "Trang chủ";
}

@section Styles {
    <style>
        /* --- 1. HERO SECTION --- */
        .hero-section {
            /* Thay thế nền đỏ cũ bằng dải màu Xanh lá ngọc dựa trên biến --bs-success */
            background: linear-gradient(135deg, var(--bs-success) 0%, #059669 100%);
            color: white;
            border-radius: var(--border-radius-lg, 16px);
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(16, 185, 129, 0.25);
        }

        .hero-pattern {
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            opacity: 0.15;
            /* Chuyển các chấm bi màu vàng cũ sang màu trắng trong suốt để tinh tế hơn */
            background-image: radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.5) 1.5px, transparent 0);
            background-size: 24px 24px;
        }

        /* --- 2. CARDS (Giữ nguyên cấu trúc, cập nhật màu sắc khi hover) --- */
        .feature-card {
            border: 1px solid var(--bs-border-color);
            border-radius: var(--border-radius-md, 12px);
            transition: all 0.3s ease;
            height: 100%;
            background: white;
            position: relative;
            overflow: hidden;
        }

            .feature-card:hover {
                transform: translateY(-5px);
            }

        .card-exam:hover {
            border-color: var(--bs-success);
            box-shadow: 0 10px 25px rgba(16, 185, 129, 0.15) !important;
        }

        .card-question:hover {
            border-color: var(--bs-primary);
            box-shadow: 0 10px 25px rgba(244, 123, 37, 0.15) !important;
        }

        .card-history:hover {
            border-color: #0d6efd;
            box-shadow: 0 10px 25px rgba(13, 110, 253, 0.15) !important;
        }

        .feature-card .icon-wrapper {
            width: 64px;
            height: 64px;
            border-radius: var(--border-radius-md, 12px);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1.2rem;
            transition: all 0.3s;
        }

        /* Icon Colors */
        .card-exam .icon-wrapper {
            background-color: var(--bs-success);
            color: white;
        }

        .card-question .icon-wrapper {
            background-color: rgba(244, 123, 37, 0.1);
            color: var(--bs-primary);
        }

        .card-history .icon-wrapper {
            background-color: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
        }

        /* --- 3. BUTTONS (Đồng bộ với .btn-primary trong site.css) --- */
        .btn-brand-cta {
            background-color: var(--bs-primary); /* Cam */
            color: #ffffff;
            border: none;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

            .btn-brand-cta:hover {
                background-color: #e0691b; /* Màu cam đậm khi hover từ site.css */
                color: #ffffff;
                box-shadow: 0 6px 15px rgba(244, 123, 37, 0.4);
                transform: translateY(-2px);
            }

        .stretched-link {
            text-decoration: none;
            font-weight: 700;
        }
    </style>
}

<div class="container py-4">
    <div class="p-5 mt-5 mb-5 hero-section">
        <div class="hero-pattern"></div>
        <div class="position-relative z-1 text-center text-lg-start d-flex flex-column flex-lg-row align-items-center justify-content-between">

            <div>
                <h1 class="display-4 fw-bold mb-2 text-white">Hệ thống Thi Trực tuyến</h1>

                <p class="fs-5 mb-4 text-white opacity-75" style="max-width: 600px;">
                    Nền tảng quản lý thi cử chuyên nghiệp. Nâng tầm ngoại ngữ - Vươn tới tương lai.
                </p>

                @if (SignInManager.IsSignedIn(User))
                {
                    if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                    {
                        <a asp-area="Admin" asp-controller="Exams" asp-action="Create" class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow">
                            <i class="bi bi-plus-circle-fill me-2"></i>Tạo Đề Thi Mới
                        </a>
                    }
                    else
                    {
                        <a asp-area="Student" asp-controller="StudentExams" asp-action="Index" class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow">
                            <i class="bi bi-play-circle-fill me-2"></i>Vào Thi Ngay
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
                    </a>
                }
            </div>

            <div class="d-none d-lg-block">
                <i class="bi bi-laptop-fill" style="font-size: 10rem; color: rgba(255, 255, 255, 0.25);"></i>
            </div>
        </div>
    </div>
</div>