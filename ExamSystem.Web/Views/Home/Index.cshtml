            class Particle {
        constructor(x, y) {
            this.x = x;
            this.y = y;
            this.baseX = x;
            this.baseY = y;
            this.size = Math.random() * 2 + 1; // Kích thước hạt ngẫu nhiên nhẹ
            this.density = (Math.random() * 20) + 10;
        }

        draw() {
            // Thêm hiệu ứng phát sáng nhẹ cho hạt
            ctx.shadowBlur = 5;
            ctx.shadowColor = "white";
            ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.closePath();
            ctx.fill();
            ctx.shadowBlur = 0; // Tắt shadow cho các hạt tiếp theo để đỡ lag
        }

        update() {
            if (mouse.x !== undefined && mouse.y !== undefined) {
                let dx = mouse.x - this.x;
                let dy = mouse.y - this.y;
                let distance = Math.sqrt(dx * dx + dy * dy);

                // Tăng bán kính tương tác lên 100 để mượt hơn
                let forceRadius = 60;

                if (distance < forceRadius) {
                    let force = (forceRadius - distance) / forceRadius;
                    let directionX = (dx / distance) * force * this.density;
                    let directionY = (dy / distance) * force * this.density;

                    this.x -= directionX;
                    this.y -= directionY;
                } else {
                    this.returnToBase();
                }
            } else {
                this.returnToBase();
            }
        }

        returnToBase() {
            // Nảy về chỗ cũ nhanh hơn một chút để tạo cảm giác linh hoạt
            this.x -= (this.x - this.baseX) / 15;
            this.y -= (this.y - this.baseY) / 15;
        }
    }

        function initParticles() {
            particlesArray = [];
            let spacing = 28;
            for (let y = spacing/2; y < canvas.height; y += spacing) {
                for (let x = spacing/2; x < canvas.width; x += spacing) {
                    particlesArray.push(new Particle(x, y));
                }
            }
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            for (let i = 0; i < particlesArray.length; i++) {
                particlesArray[i].update();
                particlesArray[i].draw();
            }
            requestAnimationFrame(animate);
        }

        resizeCanvas();
        animate();
    });
</script>