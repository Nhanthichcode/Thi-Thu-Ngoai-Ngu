@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container py-4">
    <div class="p-5 mt-5 mb-5 hero-section">
        <div class="hero-pattern"></div>
        <div class="position-relative z-1 text-center text-lg-start d-flex flex-column flex-lg-row align-items-center justify-content-between">

            <div>
                <h1 class="display-4 fw-bold mb-2 text-white">Hệ thống Thi Trực tuyến</h1>

                <p class="fs-5 mb-4 text-white opacity-75" style="max-width: 600px;">
                    Nền tảng quản lý thi cử chuyên nghiệp. Nâng tầm ngoại ngữ - Vươn tới tương lai.
                </p>

                @if (SignInManager.IsSignedIn(User))
                {
                    if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                    {
                        <a asp-area="Admin" asp-controller="Exams" asp-action="Create" class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow">
                            <i class="bi bi-plus-circle-fill me-2"></i>Tạo Đề Thi Mới
                        </a>
                    }
                    else
                    {
                        <a asp-area="Student" asp-controller="StudentExams" asp-action="Index" class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow">
                            <i class="bi bi-play-circle-fill me-2"></i>Vào Thi Ngay
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
                    </a>
                }
            </div>

            <div class="d-none d-lg-block">
                <i class="bi bi-laptop-fill" style="font-size: 10rem; color: rgba(255, 255, 255, 0.25);"></i>
            </div>
        </div>
    </div>
</div>