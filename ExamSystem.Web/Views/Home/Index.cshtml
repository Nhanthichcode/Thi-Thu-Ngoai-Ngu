<style>
    .hero-section {
        /* Gradient nền sâu hơn để làm nổi bật các hạt trắng */
        background: linear-gradient(135deg, #f47b25 0%, #d32f2f 100%);
        position: relative;
        overflow: hidden;
        border-radius: 2.5rem; /* Bo góc cực đại cho hiện đại */
        box-shadow: 0 20px 40px rgba(211, 47, 47, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

        /* Hiệu ứng Spotlight theo chuột */
        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient( circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255, 255, 255, 0.15) 0%, transparent 60% );
            pointer-events: none;
            z-index: 2;
        }

    .hero-pattern-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        opacity: 0.6;
    }

    /* Hiệu ứng trôi lửng cho Icon */
    .floating-icon {
        animation: floating 4s ease-in-out infinite;
        filter: drop-shadow(0 15px 15px rgba(0,0,0,0.2));
    }

    @@keyframes floating {
        0%

    {
        transform: translateY(0px) rotate(0deg);
    }

    50% {
        transform: translateY(-20px) rotate(2deg);
    }

    100% {
        transform: translateY(0px) rotate(0deg);
    }

    }

    /* Nâng cấp nút bấm */
    .btn-brand-cta {
        background: white !important;
        color: #d32f2f !important;
        border: none;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .btn-brand-cta:hover {
            transform: scale(1.05) translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
        }
</style>
<div class="container py-4">
    <div class="hero-section mt-5 mb-5" id="heroSection" style="min-height: 550px; display: flex; align-items: center;">
        <canvas id="particleCanvas" class="hero-pattern-canvas"></canvas>

        <div class="container position-relative z-3">
            <div class="row align-items-center">
                <div class="col-lg-7 text-center text-lg-start">
                    <h1 class="display-2 fw-bold mb-3 text-white">Hệ thống Thi <br /> Trực Tuyến</h1>
                    <p class="fs-4 mb-5 text-white opacity-75" style="max-width: 600px; line-height: 1.6;">
                        Nền tảng quản lý thi cử chuyên nghiệp.<br />
                        <span class="fw-light">Nâng tầm ngoại ngữ - Vươn tới tương lai.</span>
                    </p>

                    <div class="d-flex gap-3 justify-content-center justify-content-lg-start">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var isAdmin = User.IsInRole("Admin") || User.IsInRole("Teacher");
                            <a asp-area="@(isAdmin ? "Admin" : "Student")"
                               asp-controller="@(isAdmin ? "Exams" : "StudentExams")"
                               asp-action="Index"
                               class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow fw-bold">
                                <i class="bi @(isAdmin ? "bi-speedometer2" : "bi-play-circle-fill") me-2"></i>
                                @(isAdmin ? "TRANG QUẢN TRỊ" : "VÀO THI NGAY")
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-brand-cta btn-lg rounded-pill px-5 py-3 shadow fw-bold">
                                <i class="bi bi-box-arrow-in-right me-2"></i>ĐĂNG NHẬP NGAY
                            </a>
                        }
                    </div>
                </div>

                <div class="col-lg-5 d-none d-lg-flex justify-content-center">
                    <div class="floating-icon">
                        <i class="bi bi-laptop-fill" style="font-size: 15rem; color: rgba(255, 255, 255, 0.15);"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const hero = document.getElementById('heroSection');
        const canvas = document.getElementById('particleCanvas');

        if (!hero || !canvas) return;

        const ctx = canvas.getContext('2d');
        let particlesArray = [];
     
        let mouse = { x: undefined, y: undefined, radius: 60 };

        function resizeCanvas() {
            canvas.width = hero.offsetWidth;
            canvas.height = hero.offsetHeight;
            initParticles();
        }
        window.addEventListener('resize', resizeCanvas);

        hero.addEventListener('mousemove', function (e) {
            const rect = hero.getBoundingClientRect();
            mouse.x = e.clientX - rect.left;
            mouse.y = e.clientY - rect.top;

            hero.style.setProperty('--mouse-x', `${mouse.x}px`);
            hero.style.setProperty('--mouse-y', `${mouse.y}px`);
        });

