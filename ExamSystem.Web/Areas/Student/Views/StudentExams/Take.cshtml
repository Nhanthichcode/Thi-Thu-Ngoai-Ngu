@using ExamSystem.Core.Enums
@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@using System.Security.Claims
@inject UserManager<AppUser> UserManager
@model ExamSystem.Core.Entities.Exam
@{
    Layout = null;
    int globalIndex = 1;
    var currentUser = await UserManager.GetUserAsync(User);
    string studentName = currentUser?.FullName ?? User.Identity?.Name ?? "Thí sinh tự do";
    var orderedParts = Model.ExamParts.OrderBy(p => p.SkillType).ThenBy(p => p.OrderIndex).ToList();

    int totalQuestions = orderedParts.Sum(p => p.ExamQuestions.Count);

    // Map câu hỏi với Section để bản đồ hoạt động trơn tru
    var questionSectionMap = new Dictionary<int, int>();
    int tempQIdx = 1;
    for (int i = 0; i < orderedParts.Count; i++)
    {
        foreach (var q in orderedParts[i].ExamQuestions)
        {
            questionSectionMap[tempQIdx] = i;
            tempQIdx++;
        }
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title - ExamPortal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/css/pages/exam-take.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

</head>
<body>

    <header class="top-header">
        <div class="d-flex align-items-center gap-3">
            <div class="brand-logo">LÀM BÀI</div>
            <div class="exam-title text-muted border-start ps-3 ms-2">@Model.Title</div>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="theme-switch-wrapper">
                <label class="button-bulb" for="theme-toggle">
                    <input id="theme-toggle" type="checkbox" onchange="toggleTheme()" />
                    <div class="socket"></div>
                    <div class="light-bulb">
                        <svg fill="none" viewBox="0 0 131 151" width="22">
                            <path stroke-width="8" stroke="currentColor"
                                  d="M1.00043 50.4999C80.0004 57.4999 102 50.4999 102 50.4999C102 50.4999 125 45.9999 127 31.4999C129 16.9998 115 1.49988 107.5 3.49988C100 5.49988 83.5004 16.9999 83.5004 75.4999C83.5004 83.9786 83.8466 91.4701 84.4622 98.0884M1 100.5C43.5028 96.7338 69.5067 97.0201 84.4622 98.0884M84.4622 98.0884C97.3045 99.0058 102 100.5 102 100.5C102 100.5 125 105 127 119.5C129 134 115 149.5 107.5 147.5C101.087 145.79 88.0938 137.134 84.4622 98.0884Z">
                            </path>
                        </svg>
                        <p class="text-light-bulb m-0 flex-grow-1 text-center" id="theme-text">SÁNG</p>
                    </div>
                </label>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold bg-secondary" style="width: 28px; height: 28px; font-size: 0.8rem;">
                    @(studentName.Substring(0, 1).ToUpper())
                </div>
                <span class="fw-bold text-dark" style="font-size: 0.9rem;">@studentName</span>
            </div>
        </div>
    </header>

    <div class="action-toolbar">
        <div class="part-tabs">
            @foreach (var group in orderedParts.GroupBy(p => p.SkillType))
            {
                <div class="skill-group">
                    <div class="skill-name">@group.Key.ToString()</div>
                    @{
                        int partNumber = 1;
                        foreach (var part in group)
                        {
                            int globalIndexForPart = orderedParts.IndexOf(part);
                            <button type="button" class="tab-btn part-btn-@globalIndexForPart" onclick="goToSection(@globalIndexForPart)">
                                @partNumber
                            </button>
                            partNumber++;
                        }
                    }
                </div>
            }
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="timer-display" id="timer">00:00</div>
            <button type="button" onclick="submitExam()" class="btn btn-danger btn-sm fw-bold px-3 py-1" style="background-color: var(--brand-red);">
                NỘP BÀI
            </button>
        </div>
    </div>

    <div class="exam-container">

        <main class="main-content" id="mainContent">
            <form id="examForm" asp-action="Submit" method="post" enctype="multipart/form-data">
                <input type="hidden" name="examId" value="@Model.Id" />

                @{
                    int currentSkillPartNum = 1;
                    ExamSkill? currentSkill = null;
                }

                @for (int i = 0; i < orderedParts.Count; i++)
                {
                    var part = orderedParts[i];

                    if (part.SkillType != currentSkill)
                    {
                        currentSkill = part.SkillType;
                        currentSkillPartNum = 1;
                    }
                    else
                    {
                        currentSkillPartNum++;
                    }

                    <div class="exam-section @(i == 0 ? "active" : "")" id="section-@i">
                        <h6 class="fw-bold text-secondary mb-3 text-uppercase border-bottom pb-2">@part.SkillType.ToString() - PHẦN @currentSkillPartNum</h6>

                        @* --- LISTENING --- *@                       
                        @if (part.SkillType == ExamSkill.Listening)
                        {
                            var audio = part.ExamQuestions.FirstOrDefault()?.Question?.ListeningResource;
                            if (audio != null)
                            {
                                <div class="mc-audio-player mb-4" data-audio-id="@audio.Id" style="
                        background: linear-gradient(145deg, #0f172a 0%, #1e293b 100%);
                        border-radius: 20px;
                        padding: 24px;
                        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
                        color: #fff;
                        position: relative;
                        border: 1px solid rgba(255,255,255,0.05);">
                                    <!-- Header Info -->
                                    <div class="d-flex align-items-center justify-content-between mb-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="play-status-icon" style="background: rgba(99, 102, 241, 0.15); border-radius: 12px; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-volume-up-fill text-indigo-400" style="color: #818cf8; font-size: 1.2rem;"></i>
                                            </div>
                                            <div>
                                                <div style="font-weight: 700; font-size: 0.85rem; letter-spacing: 0.1em; color: #94a3b8; text-uppercase;">BÀI NGHE</div>
                                                <div class="audio-title" style="font-size: 1rem; color: #f8fafc; font-weight: 500;">Listening Resource #@audio.Id</div>
                                            </div>
                                        </div>
                                        <div class="badge-container">
                                            <span class="mc-listen-badge" style="background: rgba(239, 68, 68, 0.1); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; padding: 5px 12px; font-size: 0.75rem; font-weight: 600;">
                                                <i class="bi bi-shield-lock-fill me-1"></i> Khi thi thật sự bạn chỉ được nghe 1 lần duy nhất
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Audio Element -->
                                    <audio id="audio-@audio.Id" class="mc-audio-element d-none" preload="auto">
                                        <source src="@audio.AudioUrl" type="audio/mpeg">
                                    </audio>

                                    <!-- Interactive Waveform -->
                                    <div class="mc-waveform d-flex align-items-end justify-content-center gap-1 mb-4" style="height: 40px;" data-audio-id="@audio.Id">
                                        @for (int w = 0; w < 40; w++)
                                        {
                                            int h = new Random(w * 5).Next(15, 40);
                                            <div class="waveform-bar" style="width: 4px; height: @(h)%; border-radius: 4px; background: rgba(148, 163, 184, 0.2); transition: all 0.2s ease;"></div>
                                        }
                                    </div>

                                    <!-- Custom Progress Area -->
                                    <div class="audio-progress-container mb-2">
                                        <div class="mc-progress-track" style="height: 6px; background: rgba(255,255,255,0.1); border-radius: 10px; position: relative; overflow: hidden;">
                                            <div class="mc-progress" style="height: 100%; width: 0%; background: linear-gradient(90deg, #6366f1 0%, #a855f7 100%); border-radius: 10px; transition: width 0.1s linear;"></div>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between mb-4" style="font-size: 0.8rem; color: #94a3b8; font-family: 'JetBrains Mono', monospace;">
                                        <span class="mc-currenttime">00:00</span>
                                        <span class="mc-duration">00:00</span>
                                    </div>

                                    <!-- Main Controls -->
                                    <div class="d-flex align-items-center justify-content-center gap-5">
                                        <button type="button" class="mc-rewind btn-control" title="Lùi 10s" style="background: none; border: none; color: #94a3b8; font-size: 1.2rem; transition: color 0.2s;"><i class="bi bi-arrow-counterclockwise"></i></button>

                                        <button type="button" class="mc-play shadow-lg" style="
                                width: 64px; height: 64px; border-radius: 50%; border: none;
                                background: #6366f1; color: white; font-size: 1.8rem;
                                display: flex; align-items: center; justify-content: center;
                                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                            ">
                                            <i class="bi bi-play-fill"></i>
                                        </button>

                                        <button type="button" class="mc-forward btn-control" title="Tiến 10s" style="background: none; border: none; color: #94a3b8; font-size: 1.2rem; transition: color 0.2s;"><i class="bi bi-arrow-clockwise"></i></button>
                                    </div>
                                </div>
                            }
                            @foreach (var eq in part.ExamQuestions)
                            {
                                @RenderSingleQuestion(eq, part.SkillType)
                            }
                        }
                        @* --- READING --- *@
                        else if (part.SkillType == ExamSkill.Reading)
                        {
                            var passage = part.ExamQuestions.FirstOrDefault()?.Question?.ReadingPassage;
                            <div class="reading-layout">
                                @if (passage != null)
                                {
                                    <div class="passage-box">
                                        <h6 class="fw-bold text-center mb-3">@passage.Title</h6>
                                        <div class="text-dark text-justify">@Html.Raw(passage.Content)</div>
                                    </div>
                                }
                                <div class="questions-box">
                                    @foreach (var eq in part.ExamQuestions)
                                    {
                                        @RenderSingleQuestion(eq, part.SkillType)
                                    }
                                </div>
                            </div>
                        }

                        @* --- WRITING / SPEAKING --- *@
                        else
                        {
                            @foreach (var eq in part.ExamQuestions)
                            {
                                @RenderSingleQuestion(eq, part.SkillType)
                            }
                        }
                    </div>
                }
            </form>
        </main>

        <div class="sidebar-wrapper" id="sidebarWrapper">
            <div class="sidebar-toggle-btn" onclick="toggleSidebar()">
                <i class="bi bi-chevron-right" id="sidebarToggleIcon"></i>
            </div>

            <aside class="sidebar-container" id="sidebarContainer">
                <div class="sidebar-inner">
                    <div class="sidebar-header">DANH SÁCH CÂU HỎI</div>

                    <div class="map-grid custom-scroll">
                        @for (int i = 1; i <= totalQuestions; i++)
                        {
                            <button type="button" class="map-btn" id="map-btn-@i" onclick="jumpToQuestion(@i)">@i</button>
                        }
                    </div>

                    <div class="legend-box">
                        <div class="d-flex align-items-center mb-1">
                            <span class="rounded-circle me-2" style="width: 14px; height: 14px; border: 1px solid #ced4da; background-color: #fff;"></span> Chưa trả lời
                        </div>
                        <div class="d-flex align-items-center mb-1">
                            <span class="rounded-circle me-2" style="width: 14px; height: 14px; background-color: var(--answered-color);"></span> Đã trả lời
                        </div>
                        <div class="d-flex align-items-center">
                            <span class="rounded-circle me-2" style="width: 14px; height: 14px; border: 2px solid var(--brand-red); background-color: #fff5f5;"></span> Đang xem
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>


    @{
        Microsoft.AspNetCore.Html.IHtmlContent RenderSingleQuestion(ExamSystem.Core.Entities.ExamQuestion eq, ExamSkill skill)
        {
            var sb = new System.IO.StringWriter();
            var qIdx = globalIndex++;

            if (skill == ExamSkill.Writing)
            {
                // ==========================================
                // 1. KHU VỰC DÀNH RIÊNG CHO BÀI VIẾT (WRITING)
                // ==========================================
                sb.Write($"<div class='question-card' id='q-wrapper-{qIdx}'>");

                // Đề bài Viết
                sb.Write($@"<div class='q-title'>
        <span class='q-number'>Câu {qIdx}:</span>
        <textarea readonly class='form-control bg-light shadow-none border p-3 valid' rows='12' data-val='true' data-val-required='The Content field is required.' name='Content' aria-describedby='Content-error' aria-invalid='false'>{eq.Question.Content}</textarea>
        </div>");

                // Khung nhập câu trả lời & Đếm từ
                sb.Write($@"<div class='d-flex justify-content-between align-items-end mb-2'>
        <div class='fw-bold text-primary small text-uppercase'>
        <i class='bi bi-pen-fill me-1'></i> Bài làm của bạn:
        </div>
        <div class='small fw-bold text-muted'>
        Số từ: <span id='wordcount-{eq.QuestionId}' class='text-primary fs-6'>0</span>
        </div>
        </div>");
                sb.Write($"<textarea class='form-control bg-light mb-2' rows='10' name='essayAnswers[{eq.QuestionId}]' placeholder='Nhập bài làm của bạn vào đây...' oninput=\"handleWritingInput({eq.QuestionId}, {qIdx}, this.value)\"></textarea>");                

                sb.Write("</div>");
            }
            else if (skill == ExamSkill.Speaking)
            {
                // ==========================================
                // 2. KHU VỰC DÀNH RIÊNG CHO BÀI NÓI (SPEAKING)
                // ==========================================
                sb.Write($"<div class='question-card' id='q-wrapper-{qIdx}'>");

                // Hình ảnh minh họa (nếu có)
                if (!string.IsNullOrEmpty(eq.Question.MediaUrl))
                {
                    sb.Write($"<div class='mb-3 text-center'><img src='{eq.Question.MediaUrl}' class='img-fluid rounded border' style='max-height: 600px;'/></div>");
                }

                // Đề bài Nói
                sb.Write($@"<div class='q-title'>
        <span class='q-number'>Câu {qIdx}:</span>
        <textarea readonly class='form-control bg-light shadow-none border p-3 valid' rows='10' data-val='true' data-val-required='The Content field is required.' name='Content' aria-describedby='Content-error' aria-invalid='false'>{eq.Question.Content}</textarea>
        </div>");

                // Giao diện ghi âm
                sb.Write(RenderRecorderUI(eq.QuestionId, qIdx).ToString());

                sb.Write("</div>");
            }
            else
            {
                // ==========================================
                // 3. KHU VỰC DÀNH RIÊNG CHO TRẮC NGHIỆM (READING, LISTENING, GRAMMAR)
                // ==========================================
                sb.Write($"<div class='question-card' id='q-wrapper-{qIdx}'>");

                // Đề bài Trắc nghiệm
                sb.Write($@"<div class='q-title'>
        <span class='q-number'>Câu {qIdx}:</span>
        <textarea readonly class='form-control bg-light shadow-none border p-3 valid' rows='2' data-val='true' data-val-required='The Content field is required.' name='Content' aria-describedby='Content-error' aria-invalid='false'>{eq.Question.Content}</textarea>
        </div>");

                // Các lựa chọn đáp án A, B, C, D
                if (eq.Question.Answers != null)
                {
                    char alpha = 'A';
                    foreach (var ans in eq.Question.Answers)
                    {
                        sb.Write($"<label class='radio-option' for='ans_{ans.Id}'>");
                        sb.Write($"<input type='radio' name='answers[{eq.QuestionId}]' value='{ans.Id}' id='ans_{ans.Id}' onchange='markAnswered({qIdx}, true)'>");
                        sb.Write($"<div><strong>{alpha}.</strong> {ans.Content}</div>");
                        sb.Write($"</label>");
                        alpha++;
                    }
                }

                sb.Write("</div>");
            }

            return Html.Raw(sb.ToString());
        }
    }

    @* --- HELPER 2: RENDER GHI ÂM (Thu nhỏ) --- *@
    @{
        Microsoft.AspNetCore.Html.IHtmlContent RenderRecorderUI(int questionId, int qIdx)
        {
            var sb = new System.IO.StringWriter();
            sb.Write($"<div class='text-center py-2' id='recorder-{questionId}'>");
            sb.Write($"<button type='button' class='btn btn-outline-danger rounded-circle p-2 mb-1 btn-record' style='width:50px; height:50px;' onclick='toggleRecording({questionId}, {qIdx})'><i class='bi bi-mic-fill fs-5'></i></button>");
            sb.Write($"<div class='status-text text-muted small mb-1' style='font-size: 0.8rem;'>Nhấn để ghi âm</div>");
            sb.Write($"<div class='fw-bold text-danger fs-5' id='timer-{questionId}'>00:00</div>");
            sb.Write($"<audio id='playback-{questionId}' controls class='w-100 mt-2 d-none' style='height: 35px;'></audio>");
            sb.Write($"<input type='file' name='audioAnswers[{questionId}]' id='file-input-{questionId}' class='d-none' accept='audio/*' />");
            sb.Write($"</div>");
            return Html.Raw(sb.ToString());
        }
    }
    <script>
        const questionSectionMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(questionSectionMap));
      
        (function() {
            const saved = localStorage.getItem('exam_timeleft');
            window.timeLeft = (saved !== null && parseInt(saved) > 0)
                ? parseInt(saved)
                : @Model.DurationMinutes * 60;
        })();
       
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/student.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/exam-autosave.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Attach event listeners to all play buttons
            const playButtons = document.querySelectorAll('.mc-play');
            playButtons.forEach(button => {
                button.addEventListener('click', function (event) {
                    // Prevent default action immediately
                    event.preventDefault();
                    event.stopImmediatePropagation();

                    // Show confirmation prompt
                    Swal.fire({
                        title: 'Bạn đã sẵn sàng nghe?',
                        text: 'Bạn chỉ được nghe 1 lần duy nhất trong bài thi thật!',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Sẵn sàng',
                        cancelButtonText: 'Chưa',
                        reverseButtons: true
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // Trigger the play action manually if confirmed
                            const audioId = button.closest('.mc-audio-player').getAttribute('data-audio-id');
                            const audioElement = document.getElementById(`audio-${audioId}`);
                            if (audioElement) {
                                audioElement.play();
                            }
                        }
                    });
                }, true); // Use capture phase to intercept early
            });
        });
    </script>
    <script>  
        // Biến global để AutoSave sử dụng
        const userId = '@User.FindFirstValue(ClaimTypes.NameIdentifier)';
        // Khởi động auto-save khi trang load xong
        $(document).ready(function() {
            AutoSave.init(@Model.Id);
        });
    </script>
</body>
</html>
