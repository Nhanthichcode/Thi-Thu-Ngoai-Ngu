@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@{
    string currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thi Thử Ngoại Ngữ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
             style="top: 60px; z-index: 1050;" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
             style="top: 60px; z-index: 1050;" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <header>
        <nav class="navbar navbar-expand-lg fixed-top py-2">           
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Thi Thử <span class="brand-highlight">Ngoại Ngữ</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#studentNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="studentNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark @(currentController == "StudentExams" ? "active" : "")"
                               asp-area="Student" asp-controller="StudentExams" asp-action="Index">
                                <i class="bi bi-grid-fill me-1"></i> Danh sách đề thi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark @(currentController == "StudentExamsResults" ? "active" : "")"
                               asp-area="Student" asp-controller="StudentExamsResults" asp-action="Index">
                                <i class="bi bi-journal-bookmark-fill me-1"></i> Lịch sử & Kết quả
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark @(currentController == "Account" ? "active" : "")"
                                asp-area="" asp-controller="Account" asp-action="Contact">
                                <i class="bi bi-envelope-at-fill  me-1"></i>Liên hệ
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var user = await UserManager.GetUserAsync(User);
                            var fullName = user?.FullName ?? User.Identity?.Name;
                            var avatarUrl = user?.AvatarUrl;

                            <li class="nav-item d-flex align-items-center me-3">
                                <div class="theme-switch-wrapper">
                                    <label class="button-bulb" for="theme-toggle">
                                        <input id="theme-toggle" type="checkbox" onchange="toggleTheme()" />
                                        <div class="socket"></div>
                                        <div class="light-bulb">
                                            <svg fill="none" viewBox="0 0 131 151" width="22">
                                                <path stroke-width="8" stroke="currentColor"
                                                      d="M1.00043 50.4999C80.0004 57.4999 102 50.4999 102 50.4999C102 50.4999 125 45.9999 127 31.4999C129 16.9998 115 1.49988 107.5 3.49988C100 5.49988 83.5004 16.9999 83.5004 75.4999C83.5004 83.9786 83.8466 91.4701 84.4622 98.0884M1 100.5C43.5028 96.7338 69.5067 97.0201 84.4622 98.0884M84.4622 98.0884C97.3045 99.0058 102 100.5 102 100.5C102 100.5 125 105 127 119.5C129 134 115 149.5 107.5 147.5C101.087 145.79 88.0938 137.134 84.4622 98.0884Z">
                                                </path>
                                            </svg>
                                            <p class="text-light-bulb m-0 flex-grow-1 text-center" id="theme-text">SÁNG</p>
                                        </div>
                                    </label>
                                </div>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                    <span class="me-2 text-dark fw-bold">@fullName</span>
                                    @if (!string.IsNullOrEmpty(avatarUrl))
                                    {
                                        <img src="@avatarUrl" alt="Avatar" class="rounded-circle border border-warning shadow-sm"
                                             style="width: 35px; height: 35px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-warning text-danger fw-bold d-flex justify-content-center align-items-center shadow-sm"
                                             style="width: 35px; height: 35px; font-size: 0.9rem;">
                                            @(fullName?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2">
                                    <li>
                                        <div class="px-3 py-2 text-center border-bottom mb-2">
                                            <small class="text-muted d-block">Tài khoản học viên</small>
                                            <span class="fw-bold text-danger">@User.Identity?.Name</span>
                                        </div>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/Account/Profile">
                                            <i class="bi bi-person-gear me-2"></i>Thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <form id="logoutForm" asp-area="" asp-controller="Account" asp-action="Logout" method="post">                                           
                                            <button type="button" onclick="confirmLogout()" class="dropdown-item text-danger fw-bold">
                                                <i class="bi bi-power me-2"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="student-container flex-grow-1 pb-3">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container text-center">            
            <p class="small mb-0">
                &copy; @DateTime.Now.Year Thi Thử Ngoại Ngữ. Chúc bạn đạt kết quả tốt!
            </p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
      @* <script src="~/js/student.js" asp-append-version="true"></script> *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>