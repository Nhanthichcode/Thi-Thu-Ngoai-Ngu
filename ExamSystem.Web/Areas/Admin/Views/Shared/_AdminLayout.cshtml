@using Microsoft.AspNetCore.Identity
@using ExamSystem.Core.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@{
    string currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? User.Identity?.Name;
    var avatarUrl = user?.AvatarUrl;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thi Thử Ngoại Ngữ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" /> 
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light d-flex flex-column min-vh-100">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
             style="top: 60px; z-index: 1050;" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show auto-hide-alert position-fixed end-0 m-3 shadow"
             style="top: 60px; z-index: 1050;" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="d-flex" id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-heading px-3 mb-4">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <h4 class="fw-bolder m-0 text-dark">Quản <span class="brand-highlight">Lý</span></h4>
                </a>
            </div>

            <div class="list-group list-group-flush">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                   class="list-group-item list-group-item-action @(currentController == "Home" ? "active" : "")">
                    <i class="bi bi-speedometer2 text-dark"></i> Tổng quan
                </a>

                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <div class="sidebar-group-title">Quản lý Đề thi</div>
                    <div class="sidebar-group-container shadow-sm border">
                        <a asp-area="Admin" asp-controller="Exams" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "Exams" ? "active" : "")">
                            <i class="bi bi-file-earmark-text text-danger"></i> Danh sách Đề
                        </a>
                        <a asp-area="Admin" asp-controller="ExamStructures" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "ExamStructures" ? "active" : "")">
                            <i class="bi bi-diagram-3 text-info"></i> Cấu trúc đề
                        </a>
                    </div>

                    <div class="sidebar-group-title">Ngân hàng câu hỏi</div>
                    <div class="sidebar-group-container shadow-sm border">
                        <a asp-area="Admin" asp-controller="Questions" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "Questions" ? "active" : "")">
                            <i class="bi bi-collection text-warning"></i> Tất cả câu hỏi
                        </a>
                        <a asp-area="Admin" asp-controller="ReadingPassages" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "ReadingPassages" ? "active" : "")">
                            <i class="bi bi-book text-success"></i> Bài đọc
                        </a>
                        <a asp-area="Admin" asp-controller="ListeningResources" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "ListeningResources" ? "active" : "")">
                            <i class="bi bi-headphones text-danger"></i> File nghe
                        </a>
                    </div>
                }

                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-group-title">Hệ thống</div>
                    <div class="sidebar-group-container shadow-sm border">
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "Users" ? "active" : "")">
                            <i class="bi bi-people text-dark"></i> Người dùng
                        </a>
                        <a asp-area="Admin" asp-controller="ExamResults" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "ExamResults" ? "active" : "")">
                            <i class="bi bi-check2-circle text-dark"></i> Chấm thi
                        </a>
                        <a asp-area="Admin" asp-controller="Media" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "Media" ? "active" : "")">
                            <i class="bi bi-cloud-check text-dark"></i> Tài nguyên
                        </a>
                        <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                           class="list-group-item list-group-item-action @(currentController == "Settings" ? "active" : "")">
                            <i class="bi bi-gear text-dark"></i> Cấu hình
                        </a>
                    </div>
                }
            </div>
        </div>

        <div id="page-content-wrapper" class="d-flex flex-column min-vh-100">

            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top">
                <div class="container-fluid">
                    <button class="btn btn-outline-secondary text-dark" id="sidebarToggle">
                        <i class="bi bi-list fs-5"></i>
                    </button>

                    <ul class="navbar-nav ms-auto mt-2 mt-lg-0">
                        <li class="nav-item d-flex align-items-center me-3">
                            <div class="theme-switch-wrapper">
                                <label class="button-bulb" for="theme-toggle">
                                    <input id="theme-toggle" type="checkbox" onchange="toggleTheme()" />
                                    <div class="socket"></div>
                                    <div class="light-bulb">
                                        <svg fill="none" viewBox="0 0 131 151" width="24">
                                            <path stroke-width="10" stroke="currentColor"
                                                  d="M1.00043 50.4999C80.0004 57.4999 102 50.4999 102 50.4999C102 50.4999 125 45.9999 127 31.4999C129 16.9998 115 1.49988 107.5 3.49988C100 5.49988 83.5004 16.9999 83.5004 75.4999C83.5004 83.9786 83.8466 91.4701 84.4622 98.0884M1 100.5C43.5028 96.7338 69.5067 97.0201 84.4622 98.0884M84.4622 98.0884C97.3045 99.0058 102 100.5 102 100.5C102 100.5 125 105 127 119.5C129 134 115 149.5 107.5 147.5C101.087 145.79 88.0938 137.134 84.4622 98.0884Z">
                                            </path>
                                        </svg>
                                        <p class="text-light-bulb ms-2" id="theme-text">SÁNG</p>
                                    </div>
                                </label>
                            </div>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                <span class="d-none d-md-block me-2 fw-bold text-dark">@fullName</span>
                                @if (!string.IsNullOrEmpty(avatarUrl))
                                {
                                    <img src="@avatarUrl" class="rounded-circle border" style="width: 35px; height: 35px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="rounded-circle bg-danger text-white d-flex justify-content-center align-items-center" style="width: 35px; height: 35px;">
                                        @(fullName?.Substring(0, 1).ToUpper() ?? "A")
                                    </div>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2"></i> Hồ sơ</a></li>
                                <li><a class="dropdown-item" href="/" target="_blank"><i class="bi bi-box-arrow-up-right me-2"></i> Trang chủ</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form id="logoutForm" asp-area="" asp-controller="Account" asp-action="Logout" method="post">                                       
                                        <button type="button" onclick="confirmLogout()" class="dropdown-item text-danger fw-bold">
                                            <i class="bi bi-power me-2"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </nav>

            <div class="container-fluid p-4">               
                @RenderBody()
            </div>

            <footer class="admin-footer border-top footer text-muted mt-auto text-center">
                <small class="text-muted">&copy; @DateTime.Now.Year <strong>Thi Thử Ngoại Ngữ</strong>. All rights reserved.</small>
            </footer>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>