@model ExamSystem.Core.Entities.ListeningResource
@{
    ViewData["Title"] = "Thêm File Nghe";
}
<div class="sticky-top bg-white border-bottom py-3 mb-4 shadow-sm" style="z-index: 1010; top: 56px;">
    <div class="container-xxl d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-success m-0"><i class="bi bi-cloud-upload-fill"></i> Thêm File Nghe Mới</h2>
            <span class="text-muted small">Tải lên file âm thanh và nhập nội dung lời thoại</span>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
            <button type="submit" form="createForm" class="btn bg-success text-white fw-bold px-4 shadow-sm"><i class="bi bi-save me-1"></i> LƯU DỮ LIỆU</button>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white">
                <i class="bi bi-info-circle"></i> Thông tin file
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" id="createForm" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold text-secondary">
                            <i class="bi bi-tag-fill me-1"></i> Tiêu đề file nghe <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control form-control-lg" placeholder="VD: Lesson 1 - At the Airport" required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold small mb-1 ms-2">Tải lên tệp âm thanh</label>
                        <div class="input-group shadow-sm rounded-pill overflow-hidden border" 
                             style="border-color: var(--bs-border-color) !important; background-color: var(--bs-input-bg);">
        
                            <input type="file" name="audioFile" 
                                   class="form-control border-0 bg-transparent py-2 ps-3" 
                                   accept=".mp3,.wav,.ogg" required />
        
                            <span class="input-group-text border-0 bg-transparent pe-3 text-primary">
                                <i class="bi bi-music-note-beamed"></i>
                            </span>
                        </div>
                        <div class="form-text ms-2 small">Hỗ trợ định dạng: .mp3, .wav, .ogg</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Transcript" class="form-label fw-bold text-secondary">
                            <i class="bi bi-chat-quote-fill me-1"></i> Lời thoại
                        </label>
                        <textarea asp-for="Transcript" class="form-control" rows="6" placeholder="Nhập nội dung bài nghe tại đây để sinh viên tiện theo dõi..."></textarea>
                        <span asp-validation-for="Transcript" class="text-danger small"></span>
                    </div>
                   
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}