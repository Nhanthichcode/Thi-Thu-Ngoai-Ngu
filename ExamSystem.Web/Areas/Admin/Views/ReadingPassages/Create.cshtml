@model ExamSystem.Core.Entities.ReadingPassage

@{
    ViewData["Title"] = "Tạo bài đọc";
}

<div class="container-fluid px-4 mt-4">
    @* <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-primary fw-bold"><i class="bi bi-file-earmark-plus"></i> Tạo Bài Đọc Mới</h3>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
            <button type="submit" class="btn bg-success text-white fw-bold px-4 shadow-sm"><i class="bi bi-save me-1"></i> LƯU DỮ LIỆU</button>
        </div>
    </div> *@
    <div class="sticky-top bg-white border-bottom py-3 mb-4 shadow-sm" style="z-index: 1010; top: 56px;">
        <div class="container-xxl d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold text-primary m-0"><i class="bi  bi-file-earmark-plus"></i> Tạo Bài Đọc Mới</h2>
                <span class="text-muted small">Nhập nội dung cho bài đọc</span>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                <button type="submit" class="btn bg-success text-white fw-bold px-4 shadow-sm"><i class="bi bi-save me-1"></i> LƯU DỮ LIỆU</button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề bài đọc <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề (VD: Topic 1 - Environment)" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-bold">Nội dung chi tiết <span class="text-danger">*</span></label>
                    <textarea asp-for="Content" class="form-control" rows="12" placeholder="Nhập nội dung đoạn văn bài đọc tại đây..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
               
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}