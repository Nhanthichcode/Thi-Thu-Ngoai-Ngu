@model ExamSystem.Web.Areas.Admin.Controllers.MediaManagerViewModel

@{
    ViewData["Title"] = "Quản lý Tệp tin";

    // Xử lý đường dẫn
    var pathParts = string.IsNullOrEmpty(Model.CurrentPath)
        ? new string[] { }
        : Model.CurrentPath.Split(new[] { '/', '\\' }, StringSplitOptions.RemoveEmptyEntries);

    string currentAccumulatedPath = "";
}

<style>
    .folder-icon {
        color: #ffc107;
    }
    /* Màu vàng folder */
    .file-icon {
        color: #6c757d;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        font-size: 1.2rem;
        line-height: 1rem;
    }

    .table-hover tbody tr:hover {
        background-color: #fffdf0;
    }
   
</style>

<div class="container-fluid px-0">
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body d-flex justify-content-between align-items-center py-1">
            <div>
                <h4 class="fw-bold text-primary mb-1">
                    <i class="bi bi-hdd-network me-2"></i>QUẢN LÝ TỆP TIN
                </h4>
                <small class="text-muted">Quản lý hình ảnh, tài liệu và media</small>
            </div>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-light border-bottom d-flex align-items-center justify-content-between">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-action="Index" asp-route-path="" class="text-decoration-none fw-bold text-primary">
                            <i class="bi bi-house-door-fill"></i> Root
                        </a>
                    </li>

                    @for (int i = 0; i < pathParts.Length; i++)
                    {
                        currentAccumulatedPath += (i == 0 ? "" : "/") + pathParts[i];

                        if (i == pathParts.Length - 1)
                        {
                            <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@pathParts[i]</li>
                        }
                        else
                        {
                            <li class="breadcrumb-item">
                                <a asp-action="Index" asp-route-path="@currentAccumulatedPath" class="text-decoration-none">
                                    @pathParts[i]
                                </a>
                            </li>
                        }
                    }
                </ol>
            </nav>

            @if (!string.IsNullOrEmpty(Model.CurrentPath))
            {
                <a asp-action="Index" asp-route-path="@System.IO.Path.GetDirectoryName(Model.CurrentPath)"
                   class="btn btn-sm btn-white border hover-shadow">
                    <i class="bi bi-arrow-90deg-up"></i> Lên 1 cấp
                </a>
            }
        </div>

        <div class="card-body p-0">
            <div class="custom-table-scroll mb-3 shadow-sm">
                <table class="table mb-0 align-middle table-compact table-sticky-header table-custom-striped border-white">
                    <thead class="small">
                        <tr>
                            <th class="ps-4" style="width: 60px;">Icon</th>
                            <th>Tên</th>
                            <th>Kích thước</th>
                            <th>Định dạng</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder2-open display-4 opacity-50"></i>
                                    <p class="mt-2">Thư mục trống</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.Items)
                            {
                                var ext = item.Extension?.ToLower();
                                var isImage = ext == ".jpg" || ext == ".png" || ext == ".jpeg" || ext == ".gif" || ext == ".webp";

                                <tr>
                                    <td class="text-center ps-4">
                                        @if (item.IsDirectory)
                                        {
                                            <i class="bi bi-folder-fill fs-3 folder-icon"></i>
                                        }
                                        else if (isImage)
                                        {
                                            <div class="rounded border bg-light d-flex justify-content-center align-items-center" style="width: 40px; height: 40px; overflow: hidden;">
                                                <img src="~/uploads/@item.Path" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" />
                                            </div>
                                        }
                                        else
                                        {
                                            <i class="bi @item.Icon fs-4 file-icon"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (item.IsDirectory)
                                        {
                                            <a asp-action="Index" asp-route-path="@item.Path" class="text-decoration-none fw-bold text-dark stretched-link-folder">
                                                @item.Name
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="~/uploads/@item.Path" target="_blank" class="text-decoration-none text-primary fw-medium">
                                                @item.Name
                                            </a>
                                        }
                                    </td>
                                    <td class="small text-muted">@item.SizeDisplay</td>
                                    <td>
                                        @if (item.IsDirectory)
                                        {
                                            <span class="badge bg-light text-dark border">Folder</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary text-white font-monospace">@item.Extension</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            @if (!item.IsDirectory)
                                            {
                                                <button type="button" class="btn btn-sm btn-light border me-1"
                                                        onclick="copyToClipboard('/uploads/@item.Path')"
                                                        title="Copy đường dẫn">
                                                    <i class="bi bi-link-45deg"></i>
                                                </button>
                                            }

                                            <form asp-action="Delete" asp-route-path="@item.Path" method="post" class="d-inline"
                                                  onsubmit="return confirm('Cảnh báo: Bạn có chắc chắn muốn xóa @(item.IsDirectory ? "thư mục" : "tệp") này?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white small text-muted">
            Tổng cộng: <strong>@Model.Items.Count</strong> mục.
        </div>
    </div>
</div>