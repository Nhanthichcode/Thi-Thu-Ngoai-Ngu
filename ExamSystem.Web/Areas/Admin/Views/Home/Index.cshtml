@model ExamSystem.Web.Areas.Admin.Models.DashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="container-fluid py-4 px-lg-5">
    <!-- Header Dashboard -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <h3 class="fw-bold mb-1" style="color: var(--bs-primary, #f47b25);">
                <i class="bi bi-grid-1x2-fill me-2"></i>Bảng điều khiển
            </h3>
            <p class="text-muted mb-0">Xin chào Quản trị viên! Dưới đây là tổng quan hệ thống hôm nay.</p>
        </div>        
    </div>

    <!-- 4 Thẻ Thống Kê -->
    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-sm-6">
            <div class="card stat-card shadow-sm border-0 bg-white h-100"  style="background-color: #fff3cd; border: 1px solid #10b981 !important;">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div style="z-index: 1;">
                        <h6 class="text-muted text-uppercase small fw-bold mb-1">Tổng Học viên</h6>
                        <h2 class="mb-0 fw-bold text-dark">@Model.TotalStudents</h2>
                    </div>
                    <div class="stat-icon-wrapper shadow-sm" style="background-color: rgba(16, 185, 129, 0.1); color: var(--bs-success, #10b981);">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card stat-card shadow-sm border-0 bg-white h-100"  style="background-color: #fff3cd; border: 1px solid #f47b25 !important;">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div style="z-index: 1;">
                        <h6 class="text-muted text-uppercase small fw-bold mb-1">Kho Câu hỏi</h6>
                        <h2 class="mb-0 fw-bold text-dark">@Model.TotalQuestions</h2>
                    </div>
                    <div class="stat-icon-wrapper shadow-sm" style="background-color: rgba(244, 123, 37, 0.1); color: var(--bs-primary, #f47b25);">
                        <i class="bi bi-collection-fill fs-3"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card stat-card shadow-sm border-0 bg-white h-100"  style="background-color: #fff3cd; border: 1px solid #0d6efd !important;">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div style="z-index: 1;">
                        <h6 class="text-muted text-uppercase small fw-bold mb-1">Bộ Đề thi</h6>
                        <h2 class="mb-0 fw-bold text-dark">@Model.TotalExams</h2>
                    </div>
                    <div class="stat-icon-wrapper shadow-sm" style="background-color: rgba(13, 110, 253, 0.1); color: #0d6efd;">
                        <i class="bi bi-journal-text fs-3"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card stat-card shadow-sm border-0 h-100" style="background-color: #fff3cd; border: 1px solid #ffe69c !important;">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div style="z-index: 1;">
                        <h6 class="text-warning-emphasis text-uppercase small fw-bold mb-1">Chờ chấm điểm</h6>
                        <h2 class="mb-0 fw-bold text-warning-emphasis">@Model.PendingGrades</h2>
                        @if (Model.PendingGrades > 0)
                        {
                            <a asp-controller="ExamResults" asp-action="Index" class="text-decoration-none small fw-bold text-danger mt-1 d-block stretched-link">
                                Chấm ngay <i class="bi bi-arrow-right"></i>
                            </a>
                        }
                    </div>
                    <div class="stat-icon-wrapper shadow-sm bg-warning text-white">
                        <i class="bi bi-pen-fill fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Bảng Lịch sử -->
        <div class="col-xl-8">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white py-4 px-4 border-bottom-0 rounded-top-4 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-dark"><i class="bi bi-activity text-success me-2 fs-5 align-middle"></i> Lịch sử thi gần đây</h6>
                    <a asp-controller="ExamResults" asp-action="Index" class="btn btn-sm btn-outline-secondary border text-primary rounded-pill px-3 fw-bold">Xem tất cả</a>
                </div>

                <div class="custom-table-scroll">
                    <table class="table mb-0 align-middle table-compact table-sticky-header table-custom-striped border-white">
                        <thead class="small">
                            <tr>
                                <th class="ps-4">Học viên</th>
                                <th>Đề thi</th>
                                <th>Thời gian nộp</th>
                                <th class="text-center">Điểm số</th>
                                <th class="text-end pe-4">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentAttempts != null && Model.RecentAttempts.Any())
                            {
                                @foreach (var item in Model.RecentAttempts)
                                {
                                    <tr>
                                        <td class="fw-bold ps-4 border-end-0">
                                            <div class="d-flex align-items-center text-dark ">
                                                <div class="rounded-circle d-flex justify-content-center align-items-center me-2 fw-bold shadow-sm" style="width: 32px; height: 32px; background-color: var(--bs-primary, #f47b25); font-size: 0.8rem;">
                                                    <img src="@(string.IsNullOrEmpty(item.AvatarUrl) ? "/images/default-avatar.png" : item.AvatarUrl)"
                                                         alt="Avatar"
                                                         class="rounded-circle shadow-sm border border-2 border-white"
                                                         style="width: 45px; height: 45px; object-fit: cover;"
                                                         onerror="this.src='https://ui-avatars.com/api/?name=H+V&background=random';" />
                                                </div>
                                                @item.StudentName
                                            </div>
                                        </td>
                                        <td class="text-secondary fw-bold">@item.ExamTitle</td>
                                        <td class="text-muted small">@item.SubmitTime.ToString("dd/MM/yyyy - HH:mm")</td>
                                        <td class="text-center fw-bold fs-6" style="color: var(--bs-success, #10b981);">
                                            @(item.Score.HasValue? item.Score.Value.ToString("0.0") : "--")
                                        </td>
                                        <td class="text-end pe-4">
                                            @if (item.IsGraded)
                                            {
                                                 <div class="d-flex align-items-center justify-content-end gap-2">
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2 fw-normal shadow-sm"><i class="bi bi-check2-all me-1"></i>Đã chấm</span>
                                                <a asp-controller="ExamResults" asp-action="Grade" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary text-primary rounded-circle shadow-sm border d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;" title="Xem lại">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center justify-content-end gap-2">
                                                    <span class="badge bg-warning bg-opacity-10 text-warning-emphasis border border-warning rounded-pill px-3 py-2 fw-normal shadow-sm"><i class="bi bi-hourglass-split me-1"></i>Chờ chấm</span>
                                                    <a asp-controller="ExamResults" asp-action="Grade" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary text-primary rounded-circle shadow-sm border d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;" title="Chấm điểm">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <i class="bi bi-inbox text-muted opacity-25 d-block mb-2" style="font-size: 3rem;"></i>
                                        <span class="text-muted fw-bold">Chưa có bài thi nào được nộp gần đây.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Cột Phím tắt -->
        <div class="col-xl-4">
            <div class="card shadow-sm border-0 rounded-4 h-100 bg-white">
                <div class="card-header bg-white py-4 px-4 border-bottom rounded-top-4">
                    <h6 class="m-0 fw-bold text-dark"><i class="bi bi-lightning-charge-fill text-warning me-2 fs-5 align-middle"></i> Thao tác nhanh</h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex flex-column gap-3">
                        <a asp-controller="Exams" asp-action="Create" class="quick-action-btn text-decoration-none shadow-sm">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; background-color: rgba(13, 110, 253, 0.1); color: #0d6efd;">
                                    <i class="bi bi-journal-plus fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-bold mb-0">Tạo đề thi mới</div>
                                    <small class="text-muted fw-normal">Thiết lập bài thi trắc nghiệm & tự luận</small>
                                </div>
                            </div>
                        </a>

                        <a asp-controller="Questions" asp-action="Create" class="quick-action-btn text-decoration-none shadow-sm">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; background-color: rgba(244, 123, 37, 0.1); color: var(--bs-primary, #f47b25);">
                                    <i class="bi bi-node-plus fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-bold mb-0">Soạn câu hỏi</div>
                                    <small class="text-muted fw-normal">Thêm câu hỏi vào ngân hàng dữ liệu</small>
                                </div>
                            </div>
                        </a>

                        <a asp-controller="Users" asp-action="Create" class="quick-action-btn text-decoration-none shadow-sm">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; background-color: rgba(16, 185, 129, 0.1); color: var(--bs-success, #10b981);">
                                    <i class="bi bi-person-plus-fill fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-bold mb-0">Thêm học viên</div>
                                    <small class="text-muted fw-normal">Cấp tài khoản mới cho học viên</small>
                                </div>
                            </div>
                        </a>

                        <a asp-controller="Users" asp-action="Import" class="quick-action-btn text-decoration-none shadow-sm">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center me-3 border shadow-sm" style="width: 40px; height: 40px; background-color: rgba(25, 135, 84, 0.1); color: #198754;">
                                    <i class="bi bi-file-earmark-spreadsheet-fill fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-bold mb-0">Nhập từ Excel</div>
                                    <small class="text-muted fw-normal">Tạo danh sách học viên hàng loạt</small>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
