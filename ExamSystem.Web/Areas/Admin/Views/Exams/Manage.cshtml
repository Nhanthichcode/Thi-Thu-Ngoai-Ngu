@using ExamSystem.Core.Enums
@model ExamSystem.Core.Entities.Exam
@{
    ViewData["Title"] = "Soạn Đề thi: " + Model.Title;
}

<div class="d-flex justify-content-between mb-3 align-items-center">
    <div>
        <h2 class="fw-bold text-primary mb-0">@Model.Title</h2>
        <span class="text-muted">Cấu trúc: @Model.ExamParts.Count phần thi</span>
    </div>    
</div>

<div class="card shadow-sm border-0 rounded-pill highlight-card sticky-result-tabs mb-4">
    <div class="card-body p-2 px-3">
        <ul class="nav nav-pills align-items-center gap-2" id="examTabs" role="tablist">
            <!-- Listening Tab -->
            <li class="nav-item" role="presentation">
                <button class="nav-link active rounded-pill px-3 fw-bold" id="listening-tab" 
                        data-bs-toggle="pill" data-bs-target="#listening" type="button" role="tab" onclick="saveTab('listening')">
                    <i class="bi bi-headphones"></i> Listening
                </button>
            </li>

            <!-- Reading Tab (Đã sửa lỗi typo nav-pi thành nav-link) -->
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-3 fw-bold" id="reading-tab" 
                        data-bs-toggle="pill" data-bs-target="#reading" type="button" role="tab" onclick="saveTab('reading')">
                    <i class="bi bi-book"></i> Reading
                </button>
            </li>

            <!-- Writing Tab -->
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-3 fw-bold" id="writing-tab" 
                        data-bs-toggle="pill" data-bs-target="#writing" type="button" role="tab" onclick="saveTab('writing')">
                    <i class="bi bi-pen"></i> Writing
                </button>
            </li>

            <!-- Speaking Tab -->
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-3 fw-bold" id="speaking-tab" 
                        data-bs-toggle="pill" data-bs-target="#speaking" type="button" role="tab" onclick="saveTab('speaking')">
                    <i class="bi bi-mic"></i> Speaking
                </button>
            </li>

            <!-- Khác Tab -->
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-3 fw-bold" id="other-tab" 
                        data-bs-toggle="pill" data-bs-target="#other" type="button" role="tab" onclick="saveTab('other')">
                    <i class="bi bi-three-dots"></i> Khác
                </button>
            </li>

            <!-- Nút Quay lại (Đẩy sang phải) -->
            <li class="ms-auto d-flex align-items-center">
                <div class="btn-group bg-white rounded-pill shadow-sm p-1 border">
                    <button type="button" id="btnExpandAll" class="btn btn-sm rounded-pill px-3 fw-bold text-primary d-none" onclick="toggleAll('show')" title="Mở tất cả">
                        <i class="bi bi-arrows-expand"></i> <span class="ms-1">Mở rộng</span>
                    </button>
                    <button type="button" id="btnCollapseAll" class="btn btn-sm rounded-pill px-3 fw-bold text-primary" onclick="toggleAll('hide')" title="Thu gọn tất cả">
                        <i class="bi bi-arrows-collapse"></i> <span class="ms-1">Thu gọn</span>
                    </button>
                </div>
                <a asp-action="TestTake" asp-route-id="@Model.Id" target="_blank" class="btn btn-sm btn-info text-white rounded-pill px-3 mx-1  fw-bold hover-up shadow-sm">
                    <i class="bi bi-eye-fill"></i> Xem trước đề
                </a>
                <a asp-action="Index" class="btn btn-sm btn-outline-success rounded-pill px-3 fw-bold hover-up shadow-sm">
                    <i class="bi bi-arrow-left-short"></i> Lưu và thoát
                </a>
            </li>
        </ul>
    </div>
</div>

<div class="tab-content" id="examTabsContent">
    @{
        // Hàm helper render danh sách
        async Task RenderParts(ExamSystem.Core.Enums.ExamSkill skill)
        {
            var parts = Model.ExamParts.Where(p => p.SkillType == skill).OrderBy(p => p.OrderIndex).ToList();

            // Bao quanh danh sách Part bằng một div có ID để dễ thao tác DOM nếu cần
            <div id="part-container-@skill">
                @if (parts.Any())
                {
                    foreach (var part in parts)
                    {
                        // Thêm ID cho Card để xóa bằng JS
                        <div class="card mb-3 shadow-sm border" id="part-card-@part.Id">
                            <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark">@part.Name</h6>
                                    <small class="text-muted">Thứ tự: #@part.OrderIndex</small>
                                </div>

                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-warning border-0" onclick="clearPartData(@part.Id)" title="Xóa hết câu hỏi trong phần này">
                                        <i class="bi bi-eraser-fill"></i> Clear
                                    </button>

                                    <button class="btn btn-sm btn-outline-danger border-0" onclick="deletePartAjax(@part.Id)" title="Xóa phần thi này">
                                        <i class="bi bi-trash-fill"></i> Xóa
                                    </button>
                                </div>
                            </div>

                          <div class="custom-table-scroll mb-3 shadow-sm">
                            <table class="table mb-0 align-middle table-compact table-sticky-header table-custom-striped border-white">
                                <thead class="small">
                                        <tr class="text-dark">
                                            <th width="40" class="text-center">#</th>
                                            <th>Nội dung câu hỏi</th>
                                            <th width="80" class="text-center">Điểm</th>
                                            <th width="50" class="text-center">Xóa</th>
                                        </tr>
                                    </thead>
                                    @if (part.ExamQuestions.Any())
                                    {
                                        var groupedQuestions = part.ExamQuestions.OrderBy(x => x.SortOrder)
                                        .GroupBy(eq => new
                                        {
                                            ReadingId = eq.Question?.ReadingPassageId,
                                            ListeningId = eq.Question?.ListeningResourceId,
                                            ReadingTitle = eq.Question?.ReadingPassage?.Title,
                                            ListeningTitle = eq.Question?.ListeningResource?.Title
                                        }).ToList();

                                        foreach (var group in groupedQuestions)
                                        {
                                            bool isGrouped = group.Key.ReadingId != null || group.Key.ListeningId != null;
                                            string collapseId = $"collapse-{part.Id}-{group.Key.ReadingId ?? group.Key.ListeningId ?? Guid.NewGuid().GetHashCode()}";

                                            // 1. TBODY CHO HEADER (Thanh chứa Tiêu đề Bài Đọc/Nghe)
                                            if (isGrouped)
                                            {
                                                <tbody style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#@collapseId" title="Bấm để Thu gọn/Mở rộng">
                                                    <tr class="table-active bg-light">
                                                        <td colspan="4" class="fw-bold text-dark py-2 border-start border-4 @(group.Key.ReadingId != null ? "border-info" : "border-warning")">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <div>
                                                                    <i class="bi bi-chevron-down text-muted me-2 transition-icon collapse-icon"></i>
                                                                    @if (group.Key.ReadingId != null)
                                                                    {
                                                                        <span class="badge bg-info text-dark border me-2"><i class="bi bi-book me-1"></i> BÀI ĐỌC</span>
                                                                        <span>@group.Key.ReadingTitle</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge bg-warning text-dark border me-2"><i class="bi bi-headphones me-1"></i> BÀI NGHE</span>
                                                                        <span>@group.Key.ListeningTitle</span>
                                                                    }
                                                                </div>
                                                                <span class="badge bg-white text-muted border rounded-pill px-3 py-1 shadow-sm">@group.Count() câu</span>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            }

                                            // 2. TBODY CHO NỘI DUNG (Gắn class group-collapse-content để khớp với file question.js)
                                            <tbody id="@collapseId" class="collapse show @(isGrouped ? "group-collapse-content" : "")">
                                                @foreach (var eq in group)
                                                {
                                                    <tr>
                                                        <td class="text-center text-dark bg-white border-end">
                                                            @if (isGrouped)
                                                            {
                                                                <i class="bi bi-arrow-return-right text-muted me-1"></i>
                                                            }
                                                            @eq.SortOrder
                                                        </td>
                                                        <td class="bg-white">
                                                            <div class="text-dark" style="max-width: 500px;" title="@eq.Question?.Content">
                                                                @Html.Raw(eq.Question?.Content)
                                                            </div>
                                                        </td>
                                                        <td class="text-center fw-bold text-success bg-white">@eq.Score</td>
                                                        <td class="text-center bg-white">
                                                            <form asp-action="RemoveQuestionFromPart" method="post" onsubmit="return confirm('Xóa khỏi phần thi này?');">
                                                                <input type="hidden" name="examId" value="@Model.Id" />
                                                                <input type="hidden" name="examQuestionId" value="@eq.Id" />
                                                                <button class="btn btn-link text-danger p-0"><i class="bi bi-x-circle-fill fs-5"></i></button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        }
                                    }
                                    else
                                    {
                                        <tbody>
                                            <tr><td colspan="4" class="text-center text-muted py-4 small bg-light"><i class="bi bi-inbox fs-4 d-block mb-2 opacity-50"></i>Chưa có câu hỏi nào.</td></tr>
                                        </tbody>
                                    }
                                </table>
                            </div>

                            <div class="card-footer bg-white">
                                @if (!part.ExamQuestions.Any())
                                {
                                    // Nút thêm câu hỏi (Logic cũ của bạn)
                                    <div class="d-flex gap-2">
                                        @if (skill == ExamSystem.Core.Enums.ExamSkill.Listening)
                                        {
                                            <button class="btn btn-warning btn-sm" onclick="openAddModal(@part.Id, 'Listening', @((int)skill))"><i class="bi bi-headphones"></i> Chọn Bài Nghe</button>
                                        }
                                        else if (skill == ExamSystem.Core.Enums.ExamSkill.Reading)
                                        {
                                            <button class="btn btn-info btn-sm text-white" onclick="openAddModal(@part.Id, 'Reading', @((int)skill))"><i class="bi bi-book"></i> Chọn Bài Đọc</button>
                                        }
                                        else if (skill == ExamSystem.Core.Enums.ExamSkill.Writing)
                                        {
                                            <button class="btn btn-danger btn-sm text-white" onclick="openAddModal(@part.Id, 'Independent', @((int)skill))"><i class="bi bi-pen"></i> Chọn Đề Viết</button>
                                        }
                                        else if (skill == ExamSystem.Core.Enums.ExamSkill.Speaking)
                                        {
                                            <button class="btn btn-success btn-sm text-white" onclick="openAddModal(@part.Id, 'Independent', @((int)skill))"><i class="bi bi-mic"></i> Chọn Đề Nói</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-primary btn-sm" onclick="openAddModal(@part.Id, 'Independent', @((int)skill))"><i class="bi bi-plus-circle"></i> Thêm Câu hỏi</button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning py-1 small mb-0"><i class="bi bi-info-circle"></i> Đã chọn đủ câu hỏi.</div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-muted border border-dashed rounded mb-3">
                        <i class="bi bi-inbox fs-3 d-block"></i> Chưa có phần thi nào.
                    </div>
                }
            </div>

            // 2. NÚT THÊM PART MỚI (NẰM CUỐI DANH SÁCH CỦA MỖI TAB)
            <div class="d-grid gap-2 mb-4">
                <button class="btn btn-outline-primary border-dashed py-2" onclick="openCreatePartModal(@((int)skill))">
                    <i class="bi bi-plus-circle-fill"></i> Thêm Phần thi @skill.ToString() Mới
                </button>
            </div>
        }
    }

    <div class="tab-pane fade show active" id="listening" role="tabpanel">
        @{
            await RenderParts(ExamSystem.Core.Enums.ExamSkill.Listening);
        }
    </div>
    <div class="tab-pane fade" id="reading" role="tabpanel">
        @{
            await RenderParts(ExamSystem.Core.Enums.ExamSkill.Reading);
        }
    </div>
    <div class="tab-pane fade" id="writing" role="tabpanel">
        @{
            await RenderParts(ExamSystem.Core.Enums.ExamSkill.Writing);
        }
    </div>
    <div class="tab-pane fade" id="speaking" role="tabpanel">
        @{
            await RenderParts(ExamSystem.Core.Enums.ExamSkill.Speaking);
        }
    </div>
    <div class="tab-pane fade" id="other" role="tabpanel">
        @{            
            await RenderParts(ExamSystem.Core.Enums.ExamSkill.Grammar);
        }
    </div>
</div>

<div class="modal fade" id="createPartModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-folder-plus"></i> Tạo Phần thi Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-dark">
                <form id="createPartForm">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên Phần thi <span class="text-danger">*</span></label>
                        <input type="text" id="newPartName" class="form-control" placeholder="VD: Part 1" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Kỹ năng</label>
                        <select id="newPartSkill" class="form-select">
                            <option value="1">Listening</option>
                            <option value="2">Reading</option>
                            <option value="3">Writing</option>
                            <option value="4">Speaking</option>
                            <option value="5">Grammar/Vocab</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea id="newPartDesc" class="form-control" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="submitNewPart()">Lưu và Tạo</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addQuestionModal" tabindex="-1" aria-labelledby="addQuestionLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="addQuestionLabel"><i class="bi bi-database-add"></i> Chọn dữ liệu từ Ngân hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="modalLoading" class="text-center py-5">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted">Đang tải dữ liệu...</p>
                </div>

                <div id="modalContent" class="d-none">
                    <input type="hidden" id="currentPartId" />
                    <input type="hidden" id="currentType" />

                    <div class="alert alert-info py-2 small d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                        <span id="modalHint">Hệ thống sẽ lọc câu hỏi phù hợp với kỹ năng bạn chọn.</span>
                    </div>

                    <div class="d-flex align-items-center mb-3 bg-light p-2 rounded border">
                        <label class="me-2 fw-bold text-nowrap">Điểm cho mỗi câu:</label>
                        <input type="number" id="defaultScore" value="5" step="0.5" min="0" class="form-control form-control-sm" style="width: 100px;">
                    </div>

                    <div class="custom-table-scroll mb-3 shadow-sm">
                        <table class="table mb-0 align-middle table-compact table-sticky-header table-custom-striped border-white">
                            <thead class="small">
                                <tr>
                                    <th>Nội dung / Tiêu đề</th>
                                    <th width="150" class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="modalTableBody">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Modal Xem Trước Chi Tiết (Z-index 1060 để nổi lên trên Modal thêm câu hỏi) -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="bi bi-eye"></i> Xem trước Nội dung</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="previewModalBody">
                <!-- Nội dung sẽ được đổ bằng AJAX -->
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Đang tải dữ liệu...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/question.js" asp-append-version="true"></script>
    <script>
        var examId = @Model.Id;
        var currentBankData = []; // Biến toàn cục lưu dữ liệu để dùng cho hàm Preview

        // --- 1. LOGIC GIỮ TAB SAU KHI RELOAD ---
        $(document).ready(function () {
            // Lấy tab đã lưu từ LocalStorage
            var activeTab = localStorage.getItem('activeExamTab');
            if (activeTab) {
                // Kích hoạt lại tab đó
                var tabTrigger = new bootstrap.Tab(document.querySelector('#' + activeTab + '-tab'));
                tabTrigger.show();
            }
        });

        function saveTab(tabName) {
            localStorage.setItem('activeExamTab', tabName);
        }

        // --- 2. CÁC HÀM MODAL & AJAX ---
        function openCreatePartModal(skillId) {
            $('#newPartName').val('');
            $('#newPartDesc').val('');
            $('#newPartSkill').val(skillId);
            $('#createPartModal').modal('show');
            setTimeout(() => $('#newPartName').focus(), 500);
        }

        function submitNewPart() {
            var name = $('#newPartName').val();
            var skill = $('#newPartSkill').val();
            var desc = $('#newPartDesc').val();

            if (!name) { alert("Nhập tên!"); return; }

            var btn = event.target;
            btn.disabled = true;
            btn.innerText = "Đang tạo...";

            $.post('/Admin/Exams/QuickAddPart', {
                examId: examId, name: name, skill: skill, description: desc
            }, function (res) {
                if (res.success) window.location.reload();
                else { alert(res.message); btn.disabled = false; btn.innerText = "Lưu và Tạo"; }
            });
        }

        function openAddModal(partId, type, skillType) {
            $('#currentPartId').val(partId);
            $('#currentType').val(type);
            $('#addQuestionModal').modal('show');
            $('#modalLoading').removeClass('d-none');
            $('#modalContent').addClass('d-none');

            // Dùng Url.Action để đảm bảo đúng Area
            var url = '@Url.Action("GetAvailableQuestions", "Exams", new { area = "Admin" })';
            var fullUrl = url + '?examId=' + examId + '&type=' + type + '&skillType=' + skillType;

            $.get(fullUrl, function (data) {
                renderTable(data, type);
                $('#modalLoading').addClass('d-none');
                $('#modalContent').removeClass('d-none');
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.error("Lỗi API:", textStatus, errorThrown);
                alert("Lỗi tải dữ liệu. Mã lỗi: " + jqXHR.status);
                $('#modalLoading').addClass('d-none');
            });
        }

        // HÀM RENDER BẢNG VÀ NÚT XEM TRƯỚC
        function renderTable(data, type) {
            currentBankData = data; // Lưu dữ liệu vào biến toàn cục
            var html = '';

            if (!data || data.length === 0) {
                html = '<tr><td colspan="2" class="text-center py-5 text-dark">' +
                       '<i class="bi bi-database-exclamation fs-1 d-block mb-2 text-muted"></i>' +
                       'Chưa có dữ liệu nào trong ngân hàng câu hỏi phù hợp.</td></tr>';
            } else {
                data.forEach(item => {
                    // Nút Thêm / Đã chọn
                    var btnAdd = item.isSelected
                        ? '<button disabled class="btn btn-secondary btn-sm rounded-pill w-100 mb-1"><i class="bi bi-check2"></i> Đã chọn</button>'
                        : `<button class="btn btn-success btn-sm rounded-pill w-100 mb-1 shadow-sm" onclick="addItem(${item.id})"><i class="bi bi-plus-lg"></i> Thêm vào đề</button>`;

                    // Nút Xem chi tiết
                    var btnPreview = `<button class="btn btn-outline-info btn-sm rounded-pill w-100 shadow-sm fw-bold" onclick="previewItem(${item.id}, '${type}')"><i class="bi bi-eye"></i> Xem chi tiết</button>`;

                    var content = '';
                    if (type === 'Independent') {
                        content = `<div class="text-dark fw-bold mb-1">${item.content}</div>
                                   <small class="text-muted"><span class="badge bg-secondary">${item.skill}</span> | Độ khó: ${item.level}</small>`;
                    } else {
                        content = `<div class="fw-bold text-dark mb-1">${item.title}</div>
                                   <div class="small text-primary">
                                       <i class="bi bi-layers-half"></i> Hiện có: <strong>${item.questionCount} câu hỏi phụ</strong>
                                   </div>`;
                    }

                    html += `<tr>
                                <td class="ps-3 py-2">${content}</td>
                                <td class="text-center align-middle pe-3" style="width: 140px;">
                                    ${btnAdd}
                                    ${btnPreview}
                                </td>
                             </tr>`;
                });
            }

            $('#modalTableBody').html(html);

            // Cập nhật text gợi ý
            if (type === 'Independent') {
                $('#modalHint').html(`<i class="bi bi-info-circle-fill me-1"></i> Chọn câu hỏi đơn lẻ để thêm vào phần thi này.`);
            } else {
                $('#modalHint').html(`<i class="bi bi-info-circle-fill me-1"></i> Hệ thống đang hiển thị các bài <strong>${type}</strong> có sẵn câu hỏi trong ngân hàng.`);
            }
        }

        // HÀM XỬ LÝ NÚT XEM CHI TIẾT
        function previewItem(itemId, type) {
            var item = currentBankData.find(x => x.id === itemId);
            if (!item) return;

            var modalBody = $('#previewModalBody');
            $('#previewModal').modal('show');

            // Reset modal loading
            modalBody.html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Đang tải chi tiết...</p></div>');

            if (type === 'Independent') {
                var html = `<div class="mb-3">
                                <span class="badge bg-primary fs-6 me-2"><i class="bi bi-bar-chart"></i> Độ khó: ${item.level}</span>
                                <span class="badge bg-secondary fs-6"><i class="bi bi-tag"></i> ${item.skill}</span>
                            </div>
                            <div class="p-4 bg-light border rounded text-dark" style="font-size: 1.1rem; line-height: 1.6;">
                                ${item.content}
                            </div>`;
                modalBody.html(html);
            } else {
                var rType = type.toLowerCase();
                var apiUrl = '/Admin/Questions/GetResourceDetails?type=' + rType + '&id=' + itemId;

                $.get(apiUrl, function (d) {
                    if (d.success) {
                        if (rType === 'reading') {
                            modalBody.html(`
                                <h4 class="fw-bold text-info mb-3"><i class="bi bi-book"></i> ${item.title}</h4>
                                <div class="p-4 bg-light border rounded text-dark" style="font-size: 1.05rem; line-height: 1.7; max-height: 50vh; overflow-y: auto;">
                                    ${d.content}
                                </div>
                            `);
                        } else if (rType === 'listening') {
                            modalBody.html(`
                                <h4 class="fw-bold text-warning mb-3"><i class="bi bi-headphones"></i> ${item.title}</h4>
                                <div class="p-3 bg-dark border rounded text-center mb-3 shadow-sm">
                                    <audio controls class="w-100" src="${d.audioUrl}"></audio>
                                </div>
                                <h6 class="fw-bold text-secondary text-uppercase mb-2"><i class="bi bi-file-text"></i> Transcript / Bản dịch:</h6>
                                <div class="p-3 bg-light border rounded text-dark" style="max-height: 40vh; overflow-y: auto;">
                                    ${d.transcript ? d.transcript : '<i class="text-muted">Chưa có bản dịch cho file nghe này.</i>'}
                                </div>
                            `);
                        }
                    } else {
                        modalBody.html(`<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Lỗi: ${d.message}</div>`);
                    }
                }).fail(function () {
                    modalBody.html('<div class="alert alert-danger"><i class="bi bi-wifi-off"></i> Không thể kết nối đến máy chủ để lấy nội dung.</div>');
                });
            }
        }

        // HÀM GỬI LỆNH THÊM CÂU HỎI VÀO ĐỀ THI
        function addItem(itemId) {
            var partId = $('#currentPartId').val();
            var type = $('#currentType').val();
            var score = $('#defaultScore').val();

            var url = type === 'Independent'
                ? '@Url.Action("AddSingleQuestion", "Exams", new { area = "Admin" })'
                : '@Url.Action("AddResourceGroup", "Exams", new { area = "Admin" })';

            var data = type === 'Independent'
                ? { examPartId: partId, questionId: itemId, score: score }
                : { examPartId: partId, resourceId: itemId, type: type, scorePerQuestion: score };

            postForm(url, data);
        }

        function postForm(path, params) {
            var form = document.createElement("form");
            form.setAttribute("method", "post");
            form.setAttribute("action", path);
            for (var key in params) {
                var hiddenField = document.createElement("input");
                hiddenField.setAttribute("type", "hidden");
                hiddenField.setAttribute("name", key);
                hiddenField.setAttribute("value", params[key]);
                form.appendChild(hiddenField);
            }
            document.body.appendChild(form);
            form.submit();
        }

        // --- 3. AJAX DELETE & CLEAR PART ---
        function deletePartAjax(partId) {
            if (!confirm('CẢNH BÁO: Bạn chắc chắn muốn xóa vĩnh viễn phần thi này?')) return;

            const card = document.getElementById('part-card-' + partId);
            if (card) card.style.opacity = '0.5';

            $.post('/Admin/ExamParts/DeletePartAjax', { id: partId }, function (res) {
                if (res.success) {
                    $(card).fadeOut(300, function () { $(this).remove(); });
                } else {
                    alert(res.message);
                    if (card) card.style.opacity = '1';
                }
            }).fail(function () {
                alert("Lỗi kết nối server!");
                if (card) card.style.opacity = '1';
            });
        }

        function clearPartData(partId) {
            if (!confirm('Bạn muốn gỡ bỏ tất cả câu hỏi trong phần này (Giữ lại cấu trúc Part)?')) return;

            $.post('/Admin/ExamParts/ClearPartQuestionsAjax', { id: partId }, function (res) {
                if (res.success) {
                    window.location.reload();
                } else {
                    alert(res.message);
                }
            }).fail(function () {
                alert("Lỗi kết nối server!");
            });
        }
    </script>
}