@model IEnumerable<ExamSystem.Core.Entities.Exam>
@{
    ViewData["Title"] = "Quản lý Đề thi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0" style="color: var(--bs-primary, #f47b25);">
        <i class="bi bi-file-earmark-text-fill me-2"></i>Danh sách Đề thi
    </h3>
    <button type="button" class="btn text-white rounded-pill px-4 fw-bold shadow-sm hover-up"
            style="background-color: var(--bs-primary, #f47b25);"
            data-bs-toggle="modal" data-bs-target="#createExamModal">
        <i class="bi bi-plus-lg me-1"></i> Khởi tạo Đề thi Mới
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
    <div class="custom-table-scroll mb-3 shadow-sm">
        <table class="table mb-0 align-middle table-compact table-sticky-header table-custom-striped border-white">
            <thead class="small">
                <tr>
                    <th class="ps-4">Tên đề thi</th>
                    <th>Thời gian</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@item.Title</div>
                            <div class="text-muted small">@item.Description</div>
                        </td>
                        <td><span class="badge bg-light text-dark border">@item.DurationMinutes phút</span></td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success px-3">Đang mở</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border border-secondary px-3">Đã đóng</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-1"
                                    onclick="openEditExamModal(@item.Id, '@item.Title', '@item.Description', @item.DurationMinutes, '@item.StartDate.ToString("yyyy-MM-ddTHH:mm")', '@item.IsActive.ToString().ToLower()')">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold"
                                    onclick="openDeleteExamModal(@item.Id, '@item.Title')">
                                <i class="bi bi-trash3"></i> Xóa
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createExamModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-plus-circle-fill text-primary me-2"></i>Khởi tạo Đề thi Mới</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Tên đề thi</label>
                        <input name="Title" class="form-control rounded-3 border shadow-sm p-3 fw-bold" placeholder="VD: Đề thi thử VSTEP tháng 12..." required />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Thời gian (phút)</label>
                            <input name="DurationMinutes" type="number" class="form-control rounded-3 border shadow-sm" value="180" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Chọn Cấu trúc </label>
                            <select name="selectedStructureId" class="form-select rounded-3 border shadow-sm" asp-items="@(new SelectList(ViewBag.Structures, "Id", "Name"))">
                                <option value="">Tạo thủ công</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-muted text-uppercase">Mô tả / Ghi chú</label>
                        <textarea name="Description" class="form-control rounded-3 border shadow-sm" rows="3"></textarea>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn text-white fw-bold py-3 rounded-pill shadow-sm" style="background-color: var(--bs-primary, #f47b25);">Tạo & Soạn đề ngay [cite: 92]</button>
                        <button type="button" class="btn btn-light border fw-bold py-2 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editExamModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-pencil-square text-warning me-2"></i>Chỉnh sửa Đề thi</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" id="edit_Id" name="Id" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Tên đề thi (*)</label>
                        <input id="edit_Title" name="Title" class="form-control rounded-3 border shadow-sm p-2 fw-bold" required />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Thời gian (phút)</label>
                            <input id="edit_Duration" name="DurationMinutes" type="number" class="form-control rounded-3 border shadow-sm" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted text-uppercase">Ngày bắt đầu</label>
                            <input id="edit_StartDate" name="StartDate" type="datetime-local" class="form-control rounded-3 border shadow-sm" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Mô tả</label>
                        <textarea id="edit_Description" name="Description" class="form-control rounded-3 border shadow-sm" rows="3"></textarea>
                    </div>
                    <div class="mb-4 form-check">
                        <input type="checkbox" id="edit_IsActive" name="IsActive" class="form-check-input" value="true" />
                        <label class="form-check-label fw-bold" for="edit_IsActive">Mở đề thi</label>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning text-dark fw-bold py-3 rounded-pill shadow-sm">Cập nhật thay đổ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteExamModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-body p-4 text-center">
                <div class="text-danger mb-3"><i class="bi bi-exclamation-triangle-fill" style="font-size: 4rem;"></i></div>
                <h4 class="fw-bold text-dark">Xác nhận Xóa? </h4>
                <p class="text-secondary mb-4">Bạn có chắc muốn xóa đề thi <strong id="delete_Title"></strong>? Hành động này không thể hoàn tác.</p>
                <form asp-action="Delete" method="post">
                    <input type="hidden" id="delete_Id" name="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger fw-bold py-2 rounded-pill shadow-sm">Xác nhận Xóa</button>
                        <button type="button" class="btn btn-light border fw-bold py-2 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // JS đổ dữ liệu cho Modal Sửa [cite: 101]
        function openEditExamModal(id, title, desc, duration, startDate, isActive) {
            document.getElementById('edit_Id').value = id;
            document.getElementById('edit_Title').value = title;
            document.getElementById('edit_Description').value = desc;
            document.getElementById('edit_Duration').value = duration;
            document.getElementById('edit_StartDate').value = startDate;
            document.getElementById('edit_IsActive').checked = (isActive === 'true');

            new bootstrap.Modal(document.getElementById('editExamModal')).show();
        }

        // JS đổ dữ liệu cho Modal Xóa [cite: 96]
        function openDeleteExamModal(id, title) {
            document.getElementById('delete_Id').value = id;
            document.getElementById('delete_Title').innerText = title;

            new bootstrap.Modal(document.getElementById('deleteExamModal')).show();
        }
    </script>
}