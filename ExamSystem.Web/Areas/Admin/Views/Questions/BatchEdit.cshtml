                                            <input type="radio" class="form-check-input mt-0" name="Questions[@i].CorrectAnswerIndex" value="@ans" @(Model.Questions[i].CorrectAnswerIndex == ans ? "checked" : "") style="cursor:pointer; transform: scale(1.2);">
                                        </div>
                                        <input type="text" name="Questions[@i].Answer@(Convert.ToChar(65 + ans))" class="form-control bg-transparent border shadow-none fw-bold" value="@val" placeholder="Đáp án @(Convert.ToChar(65 + ans))">
                                    </div>
                                }
