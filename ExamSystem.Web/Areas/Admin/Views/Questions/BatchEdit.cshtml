                <i class="bi bi-plus-circle-fill me-2 fs-5 align-middle"></i> THÊM CÂU HỎI MỚI VÀO BÀI NÀY
            </button>
            <div style="height: 100px;"></div>
        </div>
    </div>
</form>

<template id="new-q-template">
