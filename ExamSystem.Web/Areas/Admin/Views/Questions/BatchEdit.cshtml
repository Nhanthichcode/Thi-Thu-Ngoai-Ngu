@* @model ExamSystem.Web.Models.BatchEditViewModel
@{
    ViewData["Title"] = "Sửa bài " + Model.ResourceType;
}

<style>
    .btn-dashed {
        border: 2px dashed #ced4da;
        color: #6c757d;
        background: #f8f9fa;
        transition: all 0.2s;
        border-radius: 1rem;
    }

    [data-bs-theme="dark"] .btn-dashed {
        background-color: var(--bs-body-bg) !important;
    }
        .btn-dashed:hover {
            border-color: var(--bs-primary, #f47b25);
            color: var(--bs-primary, #f47b25);
            background: #fff5f0;
        }

    .q-item {
        transition: all 0.3s ease;
    }
</style>

<form asp-action="BatchEdit" enctype="multipart/form-data" id="batchEditForm">
    <input type="hidden" asp-for="ResourceId" />
    <input type="hidden" asp-for="ResourceType" />
    <input type="hidden" asp-for="DeletedQuestionIds" id="DeletedIdsInput" />

    <div class="card shadow-sm border rounded-4 mb-5 highlight-card">

        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center rounded-top-4 sticky-top sticky-result-tabs" style="z-index: 1000; top: 0;">
            <h4 class="mb-0 fw-bold" style="color: var(--bs-primary, #f47b25);">
                <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa @(Model.ResourceType == "Reading" ? "Bài Đọc" : "Bài Nghe")
            </h4>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-light border rounded-pill fw-bold px-4 shadow-sm hover-up">
                    <i class="bi bi-x-lg align-middle me-1"></i> Hủy
                </a>
                <button type="button" class="btn text-white rounded-pill fw-bold px-4 shadow-sm hover-up" style="background-color: var(--bs-primary, #f47b25);" onclick="submitForm()">
                    <i class="bi bi-floppy-fill me-1"></i> LƯU THAY ĐỔI
                </button>
            </div>
        </div>

        <div id="error-alert" class="alert alert-danger d-none rounded-0 border-start-0 border-end-0 border-top-0 mb-0 px-4 py-2 fw-bold" style="position: sticky; top: 70px; z-index: 999;">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5 align-middle"></i> <span id="error-message"></span>
        </div>

        <div class="card-body bg-light p-4 rounded-bottom-4">

            <div class="card border shadow-sm rounded-4 mb-5">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark border-bottom pb-2 mb-4">
                        <i class="bi bi-journal-text me-2 text-primary"></i>1. Thông tin Bài @Model.ResourceType
                    </h5>

                    <div class="mb-4">
                        <label class="fw-bold mb-2">Tiêu đề bài <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control bg-light shadow-none border p-3 fw-bold fs-5" id="ResourceTitle" placeholder="Nhập tiêu đề..." />
                    </div>

                    @if (Model.ResourceType == "Reading")
                    {
                        <div class="mb-2">
                            <label class="fw-bold mb-2">Nội dung bài đọc <span class="text-danger">*</span></label>
                            <textarea asp-for="Content" class="form-control bg-light shadow-none border p-3" rows="12" style="font-family: 'Segoe UI', Arial, sans-serif; line-height: 1.7;" id="ResourceContent" placeholder="Nhập nội dung bài đọc vào đây..."></textarea>
                        </div>
                    }
                    else
                    {
                        <div class="row mb-4 bg-warning bg-opacity-10 p-3 rounded-4 border border-warning mx-0">
                            <div class="col-md-7">
                                <label class="fw-bold text-darken mb-2">File Audio hiện tại:</label>
                                <div class="d-flex align-items-center">
                                    <audio controls src="@Model.CurrentAudioUrl" class="w-100 me-3"></audio>
                                </div>
                            </div>
                            <div class="col-md-5 border-start border-warning pl-3">
                                <label class="fw-bold text-danger mb-2"><i class="bi bi-upload me-1"></i> Tải file Audio mới thay thế (nếu cần):</label>
                                <input asp-for="NewAudioFile" type="file" class="form-control bg-white shadow-none" accept="audio/*" />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="fw-bold mb-2">Transcript / Bản dịch <span class="text-danger">*</span></label>
                            <textarea asp-for="Content" class="form-control bg-light shadow-none border p-3" rows="8" id="ResourceContent" placeholder="Nhập nội dung bài nghe..."></textarea>
                        </div>
                    }
                </div>
            </div>

            <h5 class="fw-bold text-dark border-bottom pb-2 mb-4 mt-5">
                <i class="bi bi-ui-checks-grid me-2 text-success"></i>2. Danh sách câu hỏi con
            </h5>

            <div id="questions-container">
                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    <div class="card border border-light shadow-sm rounded-4 mb-4 q-item overflow-hidden" data-id="@Model.Questions[i].Id">
                        <input type="hidden" name="Questions[@i].Id" value="@Model.Questions[i].Id" />

                        <div class="card-header bg-white border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fs-6"><i class="bi bi-question-circle-fill me-1"></i> Câu hỏi #@(i + 1)</span>
                            <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" onclick="markDelete(this, @Model.Questions[i].Id)">
                                <i class="bi bi-trash3-fill"></i> Xóa câu này
                            </button>
                        </div>

                        <div class="card-body p-4">
                            <div class="row g-4">
                                <div class="col-lg-7 border-end">
                                    <label class="fw-bold small mb-2 text-muted">Nội dung câu hỏi <span class="text-danger">*</span></label>
                                    <textarea name="Questions[@i].Content" class="form-control bg-light border shadow-none mb-3 p-3 fw-bold q-content-input" rows="3" placeholder="Nhập nội dung câu hỏi...">@Model.Questions[i].Content</textarea>

                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <label class="fw-bold small mb-2 text-muted">Giải thích (Gợi ý)</label>
                                            <textarea name="Questions[@i].Explaination" class="form-control bg-light border shadow-none p-2" rows="1" placeholder="Nhập giải thích...">@Model.Questions[i].Explaination</textarea>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-bold small mb-2 text-muted">Mức độ</label>
                                            <select name="Questions[@i].Level" class="form-select bg-light border shadow-none">
                                                <option value="1" selected="@(Model.Questions[i].Level == 1)">Dễ</option>
                                                <option value="2" selected="@(Model.Questions[i].Level == 2)">Trung bình</option>
                                                <option value="3" selected="@(Model.Questions[i].Level == 3)">Khó</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-5">
                                    <label class="fw-bold small mb-2 text-success"><i class="bi bi-check2-circle me-1"></i> Đáp án trắc nghiệm (Chọn câu đúng)</label>
                                    <div class="bg-light p-3 rounded-4">
                                        @for (int ans = 0; ans < 4; ans++)
                                        {
                                            string val = "";
                                            if (ans == 0) val = Model.Questions[i].AnswerA;
                                            if (ans == 1) val = Model.Questions[i].AnswerB;
                                            if (ans == 2) val = Model.Questions[i].AnswerC;
                                            if (ans == 3) val = Model.Questions[i].AnswerD;

                                            <div class="input-group mb-2 bg-white rounded-3 shadow-sm overflow-hidden">
                                                <div class="input-group-text bg-transparent border pe-2">
                                                    <input type="radio" class="form-check-input mt-0" name="Questions[@i].CorrectAnswerIndex" value="@ans" @(Model.Questions[i].CorrectAnswerIndex == ans ? "checked" : "") style="cursor:pointer; transform: scale(1.2);">
                                                </div>
                                                <input type="text" name="Questions[@i].Answer@(Convert.ToChar(65 + ans))" class="form-control bg-transparent border shadow-none fw-bold" value="@val" placeholder="Đáp án @(Convert.ToChar(65 + ans))">
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <button type="button" class="btn btn-dashed w-100 py-3 mt-2 fw-bold fs-6" onclick="addBlankQuestion()">
                <i class="bi bi-plus-circle-fill me-2 fs-5 align-middle"></i> THÊM CÂU HỎI MỚI VÀO BÀI NÀY
            </button>

        </div>
    </div>
</form>

<template id="new-q-template">
    <div class="card border border-success shadow-sm rounded-4 mb-4 q-item overflow-hidden">
        <input type="hidden" name="Questions[{INDEX}].Id" value="0" />

        <div class="card-header bg-success bg-opacity-10 border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
            <span class="badge bg-success text-white px-3 py-2 rounded-pill fs-6"><i class="bi bi-stars me-1"></i> Câu hỏi Mới (Chưa lưu)</span>
            <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" onclick="this.closest('.q-item').remove()">
                <i class="bi bi-x-lg"></i> Hủy câu này
            </button>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-lg-7 border-end">
                    <label class="fw-bold small mb-2 text-muted">Nội dung câu hỏi <span class="text-danger">*</span></label>
                    <textarea name="Questions[{INDEX}].Content" class="form-control bg-light border shadow-none mb-3 p-3 fw-bold q-content-input" rows="3" placeholder="Nhập nội dung câu hỏi (Bắt buộc)..."></textarea>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="fw-bold small mb-2 text-muted">Giải thích (Gợi ý)</label>
                            <textarea name="Questions[{INDEX}].Explaination" class="form-control bg-light border shadow-none p-2" rows="1" placeholder="Nhập giải thích..."></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="fw-bold small mb-2 text-muted">Mức độ</label>
                            <select name="Questions[{INDEX}].Level" class="form-select bg-light border shadow-none">
                                <option value="1" selected>Dễ</option>
                                <option value="2">Trung bình</option>
                                <option value="3">Khó</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <label class="fw-bold small mb-2 text-success"><i class="bi bi-check2-circle me-1"></i> Đáp án trắc nghiệm</label>
                    <div class="bg-light p-3 rounded-4">
                        @for (int k = 0; k < 4; k++)
                        {
                            <div class="input-group mb-2 bg-white rounded-3 shadow-sm overflow-hidden">
                                <div class="input-group-text bg-transparent border pe-2">
                                    <input type="radio" class="form-check-input mt-0" name="Questions[{INDEX}].CorrectAnswerIndex" value="@k" @(k == 0 ? "checked" : "") style="cursor:pointer; transform: scale(1.2);">
                                </div>
                                <input type="text" name="Questions[{INDEX}].Answer@(Convert.ToChar(65 + k))" class="form-control bg-transparent border shadow-none fw-bold" placeholder="Đáp án @(Convert.ToChar(65 + k))">
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/question.js" asp-append-version="true"></script>
} *@

@model ExamSystem.Web.Models.BatchEditViewModel
@{
    ViewData["Title"] = "Sửa bài " + Model.ResourceType;
}

<style>
    /* 1. Các Style cơ bản từ bản cũ */
    .btn-dashed {
        border: 2px dashed #ced4da;
        color: #6c757d;
        background: #f8f9fa;
        transition: all 0.2s;
        border-radius: 1rem;
    }

    [data-bs-theme="dark"] .btn-dashed {
        background-color: var(--bs-body-bg) !important;
    }

    .btn-dashed:hover {
        border-color: var(--bs-primary, #f47b25);
        color: var(--bs-primary, #f47b25);
        background: #fff5f0;
    }

    .q-item {
        transition: all 0.3s ease;
    }

    /* 2. Style cho Split Layout (Bố cục 2 cột kéo thả) */
    .split-container {
        display: flex;
        flex-direction: row;
        height: calc(100vh - 180px); /* Tự động full màn hình trừ header */
        min-height: 600px;
        overflow: hidden;
    }

    .pane {
        overflow-y: auto;
        padding: 1rem;
    }

    #left-pane {
        flex: 0 0 45%; /* Mặc định cột trái chiếm 45% */
        min-width: 30%;
    }

    #right-pane {
        flex: 1;
        min-width: 30%;
    }

    /* Thanh kéo (Resizer) */
    .resizer {
        width: 10px;
        background-color: #e9ecef;
        cursor: col-resize;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: background-color 0.2s;
        z-index: 10;
        border-radius: 4px;
        margin: 0 5px;
    }

        .resizer:hover, .resizer.resizing {
            background-color: var(--bs-primary, #f47b25);
        }

        .resizer::after {
            content: '⋮';
            color: #adb5bd;
            font-weight: bold;
            font-size: 1.2rem;
        }

        .resizer:hover::after, .resizer.resizing::after {
            color: white;
        }
</style>

<form asp-action="BatchEdit" enctype="multipart/form-data" id="batchEditForm">
    <input type="hidden" asp-for="ResourceId" />
    <input type="hidden" asp-for="ResourceType" />
    <input type="hidden" asp-for="DeletedQuestionIds" id="DeletedIdsInput" />

    <div class="card shadow-sm border rounded-4 mb-3">
        <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center rounded-4 sticky-top" style="top: 120px; z-index: 100;">
            <h4 class="mb-0 fw-bold" style="color: var(--bs-primary, #f47b25);">
                <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa @(Model.ResourceType == "Reading" ? "Bài Đọc" : "Bài Nghe")
            </h4>
            <div class="d-flex gap-2">
                <button type="button" id="btnRestore" class="btn btn-outline-secondary rounded-pill fw-bold px-3 shadow-sm hover-up me-2 d-none" onclick="restoreQuestions()">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Khôi phục (<span id="restoreCount">0</span>)
                </button>
                <button type="button" class="btn btn-outline-danger rounded-pill fw-bold px-3 shadow-sm hover-up me-2" onclick="deleteAllQuestions()">
                    <i class="bi bi-trash3-fill me-1"></i> Xóa tất cả câu hỏi
                </button>

                <a asp-action="Index" class="btn btn-light border rounded-pill fw-bold px-4 shadow-sm hover-up">
                    Hủy
                </a>
                <button type="button" class="btn text-white rounded-pill fw-bold px-4 shadow-sm hover-up" style="background-color: var(--bs-primary, #f47b25);" onclick="submitForm()">
                    <i class="bi bi-floppy-fill me-1"></i> LƯU THAY ĐỔI
                </button>
            </div>
        </div>
    </div>

    <div id="error-alert" class="alert alert-danger d-none rounded-4 shadow-sm mb-3 px-4 py-2 fw-bold">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5 align-middle"></i> <span id="error-message"></span>
    </div>

    <div class="split-container border rounded-4 shadow-sm bg-light">

        <div class="pane bg-white rounded-start-4" id="left-pane">
            <h5 class="fw-bold text-dark border-bottom pb-2 mb-4 sticky-top bg-white pt-2" style="z-index: 5;">
                <i class="bi bi-journal-text me-2 text-primary"></i>1. Thông tin Bài @Model.ResourceType
            </h5>

            <div class="mb-4">
                <label class="fw-bold mb-2">Tiêu đề bài <span class="text-danger">*</span></label>
                <input asp-for="Title" class="form-control bg-light shadow-none border p-3 fw-bold fs-5" id="ResourceTitle" placeholder="Nhập tiêu đề..." />
            </div>

            @if (Model.ResourceType == "Reading")
            {
                <div class="mb-2">
                    <label class="fw-bold mb-2">Nội dung bài đọc <span class="text-danger">*</span></label>
                    <textarea asp-for="Content" class="form-control bg-light shadow-none border p-3" rows="20" style="font-family: 'Segoe UI', Arial, sans-serif; line-height: 1.7;" id="ResourceContent" placeholder="Nhập nội dung bài đọc vào đây..."></textarea>
                </div>
            }
            else
            {
                <div class="mb-4 bg-warning bg-opacity-10 p-3 rounded-4 border border-warning">
                    <label class="fw-bold text-darken mb-2">File Audio hiện tại:</label>
                    <audio controls src="@Model.CurrentAudioUrl" class="w-100 mb-3"></audio>

                    <label class="fw-bold text-danger mb-2 border-top border-warning pt-2"><i class="bi bi-upload me-1"></i> Thay thế File Audio mới (Nếu cần):</label>
                    <input asp-for="NewAudioFile" type="file" class="form-control bg-white shadow-none" accept="audio/*" />
                </div>

                <div class="mb-2">
                    <label class="fw-bold mb-2">Transcript / Bản dịch <span class="text-danger">*</span></label>
                    <textarea asp-for="Content" class="form-control bg-light shadow-none border p-3" rows="15" id="ResourceContent" placeholder="Nhập nội dung bài nghe..."></textarea>
                </div>
            }
        </div>

        <div class="resizer" id="resizer"></div>

        <div class="pane bg-white rounded-end-4" id="right-pane">
            <h5 class="fw-bold text-dark border-bottom pb-2 mb-4 sticky-top bg-white pt-2" style="z-index: 5;">
