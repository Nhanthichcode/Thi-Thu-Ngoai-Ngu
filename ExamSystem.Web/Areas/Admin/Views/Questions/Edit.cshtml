@* @model ExamSystem.Core.Entities.Question

@{
    ViewData["Title"] = "Chỉnh sửa câu hỏi";
}

<div class="card shadow">
    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Chỉnh sửa câu hỏi</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="MediaUrl" />

            <input type="hidden" asp-for="SkillType" id="SkillTypeHidden" value="@((int)Model.SkillType)" />

            <div class="p-3 mb-4 bg-light border rounded border-secondary d-flex align-items-center">
                <div class="me-3 fw-bold text-uppercase text-dark">Loại kỹ năng:</div>
                <span class="badge bg-primary fs-5 px-4 py-2">
                    @Model.SkillType.ToString()
                </span>
                <small class="text-muted ms-3 border-start ps-3">
                    <i class="bi bi-lock-fill"></i> Không thể thay đổi loại kỹ năng khi đang chỉnh sửa.
                </small>
            </div>

            <div class="row">
                <div class="col-md-7 border-end">

                    <div id="block-reading" class="mb-3 p-3 bg-white border rounded" style="display:none;">
                        <label class="form-label fw-bold text-info"><i class="bi bi-book"></i> Chọn Bài Đọc</label>
                        <select asp-for="ReadingPassageId" class="form-control" asp-items="ViewBag.ReadingPassageId">
                            <option value="">-- Chọn bài đọc --</option>
                        </select>
                    </div>

                    <div id="block-listening" class="mb-3 p-3 bg-white border rounded" style="display:none;">
                        <label class="form-label fw-bold text-warning"><i class="bi bi-headphones"></i> Chọn Bài Nghe</label>
                        <select asp-for="ListeningResourceId" class="form-control" asp-items="ViewBag.ListeningResourceId">
                            <option value="">-- Chọn file nghe --</option>
                        </select>
                    </div>

                    <div id="block-image" class="mb-3 p-3 bg-white border rounded" style="display:none;">
                        <label class="form-label fw-bold text-success"><i class="bi bi-image"></i> Hình ảnh minh họa (Bài Nói/Viết)</label>

                        <input type="hidden" id="deleteImageFlag" name="DeleteImageFlag" value="false" />

                        <div class="row">
                            <div class="col-md-6 text-center" id="current-image-container">
                                @if (!string.IsNullOrEmpty(Model.MediaUrl))
                                {
                                    <div class="mb-2 p-2 border rounded" id="current-image-wrapper">
                                        <img src="@Model.MediaUrl" class="img-thumbnail" style="max-height: 500px; width: auto; max-width: 100%;" id="current-image-tag" />
                                        <div class="small text-muted mt-1">Ảnh hiện tại</div>

                                        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="deleteCurrentMedia()">
                                            <i class="bi bi-trash"></i> Xóa ảnh
                                        </button>

                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted small py-4 border rounded bg-light" id="no-image-placeholder">Chưa có ảnh</div>
                                }
                            </div>

                            <div class="col-md-6 text-center">
                                <div class="mb-2 p-2 border rounded d-none" id="preview-container">
                                    <img id="img-preview" src="#" class="img-thumbnail" style="max-height: 500px; width: auto; max-width: 100%;" />
                                    <div class="small text-success fw-bold mt-1">Ảnh mới sẽ thay thế</div>
                                </div>
                            </div>
                        </div>

                        <label class="mt-2 fw-bold">Tải lên ảnh mới:</label>
                        <input type="file" name="imageFile" id="imageInput" class="form-control" accept="image/*" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-bold">Nội dung câu hỏi / Đề bài (*)</label>
                        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Level" class="form-label">Độ khó</label>
                            <select asp-for="Level" class="form-control">
                                <option value="1">Dễ</option>
                                <option value="2">Trung bình</option>
                                <option value="3">Khó</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Explaination" class="form-label">Giải thích đáp án</label>
                        <textarea asp-for="Explaination" class="form-control" rows="2"></textarea>
                    </div>
                </div>

                <div class="col-md-5 bg-light p-3">

                    <div id="block-answers">
                        <h5 class="text-success border-bottom pb-2">Các lựa chọn trả lời</h5>

                        @for (int i = 0; i < Model.Answers.Count; i++)
                        {
                            <div class="card mb-2">
                                <div class="card-body p-2">
                                    <input type="hidden" name="Answers[@i].Id" value="@Model.Answers[i].Id" />
                                    <input type="hidden" name="Answers[@i].QuestionId" value="@Model.Id" />

                                    <div class="input-group">
                                        <div class="input-group-text">
                                            <input class="form-check-input mt-0" type="radio" name="CorrectAnswerIndex" value="@i" @(Model.Answers[i].IsCorrect == true ? "checked" : "")>
                                        </div>
                                        <input type="text" name="Answers[@i].Content" value="@Model.Answers[i].Content" class="form-control" placeholder="Đáp án @(Convert.ToChar(65 + i))">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div id="block-no-answers" class="alert alert-info text-center mt-3" style="display:none;">
                        <i class="bi bi-info-circle-fill fs-4"></i><br />
                        <strong>Kỹ năng Tự luận (Nói/Viết)</strong><br />
                        Hệ thống sẽ không lưu các đáp án trắc nghiệm ở trên.
                    </div>

                </div>
            </div>

            <div class="mt-4 text-center border-top pt-3">
                <button type="submit" class="btn btn-warning btn-lg px-5"><i class="bi bi-check-lg"></i> Cập nhật thay đổi</button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/question.js" asp-append-version="true"></script>
} *@
@using ExamSystem.Core.Enums 
@model ExamSystem.Core.Entities.Question

@{
    ViewData["Title"] = "Chỉnh sửa câu hỏi";

    // --- LOGIC C# RAZOR ĐỂ XÁC ĐỊNH GIAO DIỆN ---
    // Kiểm tra xem câu hỏi này có phải là Kỹ năng Nói (Speaking) hay không
    bool isSpeaking = Model.SkillType == ExamSkill.Speaking;

    // Thiết lập Class cho Cột Trái (Nội dung)
    // Nếu là Speaking -> col-12 (Full trang), nếu khác -> col-lg-7 (Chiếm 7/12 trang)
    string leftColClass = isSpeaking ? "col-12" : "col-lg-7";

    // Thiết lập Class cho Cột Phải (Đáp án)
    // Nếu là Speaking -> d-none (Ẩn sạch luôn), nếu khác -> col-lg-5 (Hiện 5/12 trang)
    string rightColClass = isSpeaking ? "d-none" : "col-lg-5";

    // Thiết lập Độ cao tối đa cho ảnh minh họa
    // Nếu full trang thì cho ảnh cao 400px, nếu 2 cột thì 180px
    string imageHeight = isSpeaking ? "400px" : "180px";
}

<form asp-action="Edit" enctype="multipart/form-data">
    <div class="card shadow-sm border rounded-4 mb-5 highlight-card">

        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center rounded-top-4 sticky-result-tabs" style="z-index: 100; top: 0px;">
            <h4 class="mb-0 fw-bold" style="color: var(--bs-primary, #f47b25);">
                <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa câu hỏi
            </h4>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-light border rounded-pill fw-bold px-4 shadow-sm hover-up">
                    <i class="bi bi-arrow-left-short fs-5 align-middle"></i> Trở về
                </a>
                <button type="submit" class="btn text-white rounded-pill fw-bold px-4 shadow-sm hover-up" style="background-color: var(--bs-primary, #f47b25);">
                    <i class="bi bi-floppy-fill me-1"></i> Cập nhật thay đổi
                </button>
            </div>
        </div>

        <div class="card-body bg-light p-4 rounded-bottom-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="MediaUrl" />
            <input type="hidden" asp-for="SkillType" id="SkillTypeHidden" value="@((int)Model.SkillType)" />

            <div class="p-3 mb-4 bg-white border border-info rounded-4 d-flex align-items-center shadow-sm">
                <div class="me-3 fw-bold text-uppercase text-secondary"><i class="bi bi-tags-fill me-2"></i>Loại kỹ năng:</div>
                <span class="badge bg-info bg-opacity-10 text-info border border-info fs-6 px-4 py-2 rounded-pill shadow-sm">
                    @Model.SkillType.ToString()
                </span>
                <small class="text-muted ms-3 border-start ps-3">
                    <i class="bi bi-lock-fill text-warning"></i> Không thể thay đổi loại kỹ năng khi đang chỉnh sửa.
                </small>
            </div>

            <div class="row g-4">
                <div class="@leftColClass">
                    <div class="card border shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark border-bottom pb-2 mb-4"><i class="bi bi-journal-text me-2 text-primary"></i>Nội dung Đề bài</h5>                          

                            <div id="block-reading" class="mb-3 p-3 bg-info bg-opacity-10 border border-info rounded-4" style="display:none;">
                                <label class="form-label fw-bold text-info"><i class="bi bi-book"></i> Chọn Bài Đọc</label>
                                <select asp-for="ReadingPassageId" class="form-select border-info shadow-none" asp-items="ViewBag.ReadingPassageId">
                                    <option value="">-- Chọn bài đọc --</option>
                                </select>
                            </div>

                            <div id="block-listening" class="mb-3 p-3 bg-warning bg-opacity-10 border border-warning rounded-4" style="display:none;">
                                <label class="form-label fw-bold text-warning text-darken"><i class="bi bi-headphones"></i> Chọn Bài Nghe</label>
                                <select asp-for="ListeningResourceId" class="form-select border-warning shadow-none" asp-items="ViewBag.ListeningResourceId">
                                    <option value="">-- Chọn file nghe --</option>
                                </select>
                            </div>

                            <div id="block-image" class="mb-3 p-3 bg-success bg-opacity-10 border border-success rounded-4" style="display:none;">
                                <label class="form-label fw-bold text-success"><i class="bi bi-image"></i> Hình ảnh minh họa (Bài Nói/Viết)</label>
                                <input type="hidden" id="deleteImageFlag" name="DeleteImageFlag" value="false" />

                                <div class="row g-3">
                                    <div class="col-md-6 text-center" id="current-image-container">
                                        @if (!string.IsNullOrEmpty(Model.MediaUrl))
                                        {
                                            <div class="p-2 bg-white border rounded-3 shadow-sm h-100 d-flex flex-column justify-content-center align-items-center" id="current-image-wrapper">
                                                <img src="@Model.MediaUrl" class="img-fluid rounded border shadow" style="max-height: @imageHeight;" id="current-image-tag" />
                                                <div class="small text-muted mt-2 fw-bold">Ảnh hiện tại</div>
                                                <button type="button" class="btn btn-sm btn-outline-danger mt-2 rounded-pill px-3" onclick="deleteCurrentMedia()">
                                                    <i class="bi bi-trash3-fill"></i> Xóa ảnh này
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted small py-4 border rounded-3 bg-white shadow-sm h-100 d-flex flex-column justify-content-center align-items-center" id="no-image-placeholder">
                                                <i class="bi bi-image text-muted opacity-25 d-block fs-1 mb-2"></i> Chưa có ảnh
                                            </div>
                                        }
                                    </div>

                                    <div class="col-md-6 text-center">
                                        <div class="p-2 bg-white border border-success border-2 rounded-3 shadow-sm h-100 d-flex flex-column justify-content-center align-items-center d-none" id="preview-container">
                                            <img id="img-preview" src="#" class="img-fluid rounded border shadow" style="max-height: @imageHeight;" />
                                            <div class="small text-success fw-bold mt-2"><i class="bi bi-check-circle-fill"></i> Ảnh sẽ thay thế</div>
                                        </div>
                                    </div>
                                </div>

                                <label class="mt-3 fw-bold small">Tải lên ảnh mới:</label>
                                <input type="file" name="imageFile" id="imageInput" class="form-control bg-white shadow-none" accept="image/*" />
                            </div>

                            <div class="mb-4">
                                <label asp-for="Content" class="form-label fw-bold">Nội dung câu hỏi / Đề bài <span class="text-danger">*</span></label>
                                <textarea asp-for="Content" class="form-control bg-light shadow-none border p-3" rows="5"></textarea>
                                <span asp-validation-for="Content" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Level" class="form-label fw-bold">Mức độ khó</label>
                                    <select asp-for="Level" class="form-select bg-light border shadow-none border">
                                        <option value="1">Dễ</option>
                                        <option value="2">Trung bình</option>
                                        <option value="3">Khó</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-2 explained-block">
                                <label asp-for="Explaination" class="form-label fw-bold">Giải thích đáp án (Gợi ý)</label>
                                <textarea asp-for="Explaination" class="form-control bg-light shadow-none border p-3" rows="3" placeholder="Nhập lời giải chi tiết giúp học viên hiểu bài hơn..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="@rightColClass">
                    <div class="card border shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div id="block-answers">
                                <h5 class="fw-bold text-success border-bottom pb-2 mb-4"><i class="bi bi-ui-checks-grid me-2"></i>Các lựa chọn trả lời</h5>


                                @for (int i = 0; i < Model.Answers.Count; i++)
                                {
                                    <div class="card mb-3 border border-light shadow-sm rounded-4 hover-up transition-all" style="background-color: #fafafa;">
                                        <div class="card-body p-2">
                                            <input type="hidden" name="Answers[@i].Id" value="@Model.Answers[i].Id" />
                                            <input type="hidden" name="Answers[@i].QuestionId" value="@Model.Id" />

                                            <div class="input-group input-group-lg">
                                                <div class="input-group-text bg-transparent border">
                                                    <input class="form-check-input mt-0 checkbox-xl" type="radio" name="CorrectAnswerIndex" value="@i" @(Model.Answers[i].IsCorrect == true ? "checked" : "") style="cursor:pointer; transform: scale(1.3);" title="Chọn làm đáp án đúng">
                                                </div>
                                                <input type="text" name="Answers[@i].Content" value="@Model.Answers[i].Content" class="form-control bg-transparent border fw-bold text-dark shadow-none" placeholder="Nhập đáp án @(Convert.ToChar(65 + i))...">
                                            </div>
                                        </div>
                                    </div>
                                }
                                <div class="text-center mt-3">
                                    <small class="text-muted"><i class="bi bi-lightbulb text-warning"></i> Chọn nút tròn bên trái để đánh dấu đáp án đúng</small>
                                </div>
                            </div>

                            <div id="block-no-answers" class="alert alert-info text-center mt-3 border-info rounded-4 shadow-sm" style="display:none;">
                                <i class="bi bi-chat-square-quote-fill fs-1 d-block mb-3 text-info opacity-75"></i>
                                <h5 class="fw-bold mb-1">Kỹ năng Tự luận</h5>
                                <span class="small">Hệ thống sẽ không yêu cầu cấu hình đáp án trắc nghiệm cho câu hỏi này.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/question.js" asp-append-version="true"></script>
}