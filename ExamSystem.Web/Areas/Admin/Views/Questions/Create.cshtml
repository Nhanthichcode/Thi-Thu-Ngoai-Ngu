@model ExamSystem.Web.Models.UnifiedCreateViewModel
@{
    ViewData["Title"] = "Soạn câu hỏi theo kỹ năng";
}
<form asp-action="Create" enctype="multipart/form-data" id="createForm">

    <div class="sticky-top bg-white border-bottom py-3 mb-4 shadow-sm" style="z-index: 1010; top: 56px;">
        <div class="container-xxl d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold m-0" style="color: var(#f47b25)"><i class="bi bi-pencil-square"></i> SOẠN CÂU HỎI MỚI</h4>               
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                <button type="submit" class="btn bg-success text-white fw-bold px-4 shadow-sm"><i class="bi bi-save me-1"></i> LƯU DỮ LIỆU</button>
            </div>
        </div>
    </div>

    <div class="container-xxl pb-5">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-3">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-bold text-secondary text-uppercase small mb-1">Loại kỹ năng</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-lightning-charge text-danger"></i></span>
                            <select asp-for="SkillType" id="SkillSelect" class="form-select fw-bold text-primary"
                                    asp-items="Html.GetEnumSelectList<ExamSystem.Core.Enums.ExamSkill>()">
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold text-secondary text-uppercase small mb-1">Độ khó chung</label>
                        <select asp-for="Level" class="form-select">
                            <option value="1">Dễ</option>
                            <option value="2">Trung bình</option>
                            <option value="3">Khó</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-5 skill-resource-col" id="leftPane" style="display:none;">
                <div class="resource-sticky-pane">

                    <div id="section-reading" class="form-section" style="display:none;">
                        <div class="card border-info shadow-sm mb-3">
                            <div class="card-header bg-info text-white fw-bold">
                                <i class="bi bi-book-half"></i> Tài liệu Đọc hiểu
                            </div>
                            <div class="card-body p-3 bg-light">
                                <ul class="nav nav-pills mb-3" role="tablist">
                                    <li class="nav-item"><button class="nav-link active btn-sm" data-bs-toggle="pill" data-bs-target="#tab-read-old" type="button">Chọn bài cũ</button></li>
                                    <li class="nav-item"><button class="nav-link btn-sm ms-1" data-bs-toggle="pill" data-bs-target="#tab-read-new" type="button"><i class="bi bi-plus"></i> Tạo bài mới</button></li>
                                </ul>

                                <div class="tab-content">
                                    <div class="tab-pane fade show active" id="tab-read-old">
                                        <select asp-for="ReadingPassageId" id="SelectReadingId" class="form-select form-select-lg border-info" asp-items="ViewBag.ReadingPassageId">
                                            <option value="">-- Chọn bài đọc để hiển thị --</option>
                                        </select>

                                        <div id="ReadingPreviewContainer" class="mt-3 d-none">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <label class="section-label m-0 text-info">NỘI DUNG CHI TIẾT</label>
                                            </div>
                                            <div id="ReadingPreview" class="content-display bg-white" style="font-size: 14px;"></div>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="tab-read-new">
                                        <input asp-for="NewReadingTitle" class="form-control mb-2 fw-bold" placeholder="Nhập tiêu đề bài đọc..." />
                                        <textarea asp-for="NewReadingContent" class="form-control content-display" rows="12" placeholder="Paste nội dung bài đọc vào đây..."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="section-listening" class="form-section" style="display:none;">
                        <div class="card border-warning shadow-sm mb-3">
                            <div class="card-header bg-warning text-dark fw-bold">
                                <i class="bi bi-headphones"></i> Tài liệu Nghe
                            </div>
                            <div class="card-body p-3 bg-light">
                                <ul class="nav nav-pills mb-3" role="tablist">
                                    <li class="nav-item"><button class="nav-link active btn-sm border border-warning" data-bs-toggle="pill" data-bs-target="#tab-list-old" type="button">Chọn file cũ</button></li>
                                    <li class="nav-item"><button class="nav-link btn-sm ms-1 border border-warning" data-bs-toggle="pill" data-bs-target="#tab-list-new" type="button"><i class="bi bi-cloud-arrow-up"></i> Tải mới</button></li>
                                </ul>

                                <div class="tab-content">
                                    <div class="tab-pane fade show active" id="tab-list-old">
                                        <select asp-for="ListeningResourceId" id="SelectListeningId" class="form-select form-select-lg border-warning" asp-items="ViewBag.ListeningResourceId">
                                            <option value="">-- Chọn bài nghe để hiển thị --</option>
                                        </select>

                                        <div id="ListeningPreviewContainer" class="mt-3 d-none">
                                            <div class="p-2 bg-white rounded mb-3 border text-center shadow-sm">
                                                <audio id="AudioPlayer" controls class="w-100"></audio>
                                            </div>
                                            <label class="section-label text-warning">BẢN DỊCH / TRANSCRIPT</label>
                                            <div id="TranscriptPreview" class="content-display bg-white" style="font-size: 14px;"></div>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="tab-list-new">
                                        <input asp-for="NewListeningTitle" class="form-control mb-2 fw-bold" placeholder="Tiêu đề bài nghe..." />
                                        <div class="input-group mb-2">
                                            <span class="input-group-text"><i class="bi bi-file-earmark-music"></i></span>
                                            <input asp-for="NewListeningFile" type="file" class="form-control" accept="audio/*" />
                                        </div>
                                        <textarea asp-for="NewListeningTranscript" class="form-control content-display" rows="8" placeholder="Nhập Transcript / Bản dịch (nếu có)..."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="section-image" class="form-section" style="display:none;">
                        <div class="card border-success shadow-sm mb-3">
                            <div class="card-header bg-success text-white fw-bold">
                                <i class="bi bi-mic-fill"></i> Thông tin Bài Nói (Speaking)
                            </div>
                            <div class="card-body bg-light p-3">

                                <label class="fw-bold small mb-1 text-success">Tiêu đề bài/Nội dung bài Nói <span class="text-danger">*</span></label>
                                <input asp-for="NewSpeakingTitle" class="form-control mb-3 fw-bold border-success shadow-sm" placeholder="Nhập tiêu đề phần thi Nói (VD: Speaking Part 1)..." />

                                <label class="fw-bold small mb-1 text-success">Hình ảnh minh họa (Nếu có)</label>
                                <input asp-for="CommonImageFile" type="file" class="form-control mb-3 border-success shadow-sm" accept="image/*" onchange="previewImage(this)" />

                                <div class="text-center">
                                    <img id="imgPreview" src="" alt="Preview" class="img-thumbnail shadow-sm d-none rounded-3" style="max-height: 250px; width: auto; max-width: 100%; object-fit: contain;" />
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- THÊM MỚI: Khối hiển thị form cho Writing -->
                    <div id="section-writing" class="form-section" style="display:none;">
                        <div class="card border-primary shadow-sm mb-3">
                            <div class="card-header bg-primary text-white fw-bold">
                                <i class="bi bi-pencil-fill"></i> Thông tin Bài Viết (Writing)
                            </div>
                            <div class="card-body bg-light p-3">
                                <label class="fw-bold small mb-1 text-primary">Nội dung bài Viết (Writing Prompt) <span class="text-danger">*</span></label>
                                <textarea name="WritingPrompt" class="form-control fw-bold border-primary shadow-sm" rows="12" placeholder="Nhập đề bài luận hoặc chủ đề viết vào đây..."></textarea>

                                <div class="mt-3 text-muted small">
                                    <i class="bi bi-info-circle me-1"></i> Sinh viên sẽ đọc đề bài này và nộp bài luận (tự luận) vào ô tương ứng.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-12 questions-col" id="rightPane">
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                    <h5 class="text-secondary fw-bold m-0"><i class="bi bi-list-check"></i> DANH SÁCH CÂU HỎI</h5>
                    <span class="badge bg-primary rounded-pill" id="totalQuestionsBadge">0 câu</span>
                </div>

                <div id="questions-container">
                </div>

                <button type="button" class="btn btn-dashed w-100 py-3 mt-2 fw-bold shadow-sm" onclick="addQuestion()">
                    <i class="bi bi-plus-circle fs-4 d-block mb-1"></i>
                    Thêm câu hỏi tiếp theo
                </button>
            </div>

        </div>
    </div>
</form>

<template id="q-template">
    <div class="card mb-4 border-0 shadow-sm question-card q-item">
        <div class="card-header bg-white py-2 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary">
                <span class="badge bg-primary rounded-pill me-2 q-num">1</span>
                Nội dung câu hỏi
            </h6>
            <button type="button" class="btn btn-outline-danger btn-sm border-0" onclick="removeQ(this)" title="Xóa câu này">
                <i class="bi bi-trash"></i>
            </button>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="fw-bold small text-muted mb-1">Đề bài / Nội dung hỏi <span class="text-danger">*</span></label>
                <textarea name="Questions[{INDEX}].Content" class="form-control fw-bold border-primary" rows="2" placeholder="Nhập câu hỏi tại đây..."></textarea>
            </div>

            <div class="mb-3 explain-block">
                <label class="fw-bold small text-muted mb-1">Giải thích (Tùy chọn)</label>
                <textarea name="Questions[{INDEX}].Explaination" class="form-control text-secondary bg-light" rows="2" placeholder="Giải thích vì sao chọn đáp án đúng..."></textarea>
            </div>

            <div class="answer-block bg-light p-3 rounded border">
                <label class="section-label text-success mb-2">ĐÁP ÁN TRẮC NGHIỆM (TÍCH VÀO CÂU ĐÚNG)</label>
                <div class="row g-2">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="col-md-6">
                            <div class="input-group input-group-sm shadow-sm bg-white rounded">
                                <div class="input-group-text bg-white border-end-0">
                                    <input type="radio" class="form-check-input mt-0 pointer" name="Questions[{INDEX}].CorrectAnswerIndex" value="@i" @(i == 0 ? "checked" : "") style="cursor:pointer">
                                </div>
                                <input type="text" name="Questions[{INDEX}].Answer@(Convert.ToChar(65 + i))" class="form-control border-start-0 ps-0 fw-medium" placeholder="Đáp án @(Convert.ToChar(65 + i))">
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="no-answer-block d-none">
                <div class="text-center text-muted p-3 bg-light rounded w-100 border border-dashed">
                    <i class="bi bi-pen fs-3 text-secondary mb-1 d-block"></i>
                    <span class="fw-bold">Câu hỏi Tự luận (Không có trắc nghiệm)</span>
                </div>
            </div>
        </div>
    </div>
</template>
@section Scripts {
    <script src="~/js/question.js" asp-append-version="true"></script>
}
